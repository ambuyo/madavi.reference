---
const steps = [
  {
    num: "1",
    title: "Answer 9 Quick Questions",
    time: "Takes less than 60 seconds",
    description: "Complete our focused assessment covering your AI adoption stage, goals, team readiness, and infrastructure. No technical credentials required.",
  },
  {
    num: "2",
    title: "Our AI Engine Scores You Instantly",
    time: "Real-time, as you complete the form",
    description: "Our scoring engine evaluates your responses across 23 dimensions — strategy, data, technology, governance, and ROI readiness — against industry benchmarks.",
  },
  {
    num: "3",
    title: "Get Your AI Readiness Score + Roadmap",
    time: "Delivered in 60 seconds",
    description: "Receive your personalised AI Readiness Score, maturity level, and a custom roadmap outlining your highest-impact next moves — immediately on submission.",
  },
];
---

<div class="h-full flex flex-col p-8 lg:p-12" style="background-color: #005B65;">
  <div class="mb-10">
    <h2 class="text-white font-display font-bold leading-tight tracking-tight" style="font-size: clamp(1.4rem, 2.5vw, 2rem);">
      The Process (How it Works)
    </h2>
  </div>

  <div class="flex flex-col">
    {steps.map((step, i) => (
      <div class="flex gap-5" style="align-items: stretch;">
        {/* Left: number + dotted line — stretches full height of row */}
        <div class="flex flex-col items-center flex-shrink-0" style="width: 36px;">
          <div
            class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-sm font-bold text-white flex-shrink-0"
            style="border-color: rgba(255,255,255,0.6);"
          >
            {step.num}
          </div>
          {i < steps.length - 1 && (
            <div style="flex: 1; width: 0; border-left: 2px dotted rgba(255,255,255,0.4); margin-top: 6px; margin-bottom: 0;" />
          )}
        </div>

        {/* Right: content */}
        <div class={i < steps.length - 1 ? "pb-10" : ""}>
          <p class="text-white font-bold text-base leading-snug">{step.title}</p>
          <p class="text-sm italic mt-1" style="color: rgba(255,255,255,0.6);">{step.time}</p>
          <p class="text-sm mt-2 leading-relaxed" style="color: rgba(255,255,255,0.8);">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
