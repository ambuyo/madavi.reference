---
// Assets
import { Image } from "astro:assets";
import couple from "@/images/assets/futuristic.png";
import Shield from "@/components/assets/Shield.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="paddingLess">
    <div class="grid grid-cols-1 lg:grid-cols-2">
      <Image
        src={couple}
        width={1200}
        height={800}
        alt="Professional accounting services background"
        class="w-full h-full object-cover object-top"
      />
      <div
        class="p-8 lg:p-12 lg:px-16 bg-black text-balance lg:order-first h-full flex flex-col justify-between"
      > 
        <div>
          <Text
            tag="h3"
            variant="displayLG"
            class="text-white font-display font-medium mt-24"
          >
            Ready to Outpace the Market?
          </Text>
          <Text tag="p" variant="textXL" class="text-white font-medium mt-4">
            From AI maturity to high-converting brand strategy, we engineer the blueprint for your growth.
          </Text>
        </div>
        <div class="flex flex-col lg:flex-row gap-2 mt-8">
          <Button
            variant="muted"
            size="xs"
            isLink={true}
            href="/get-a-proposal"
            class="w-full lg:w-fit"
          >
            Get A Custom Proposal
          </Button>
          <Button
            variant="mutedDark"
            size="xs"
            isLink={true}
            href="/free-ai-audit"
            class="w-full lg:w-fit"
            style="background-color: #FF5000; border-color: #FF5000;"
          >
            Free AI Audit
          </Button>
        </div>
      </div>
    </div>
  </Wrapper>
</section>
