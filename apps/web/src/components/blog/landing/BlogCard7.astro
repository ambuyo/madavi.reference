---
import { Image } from "astro:assets";
import Text from "@/components/fundations/elements/Text.astro";
import readingTime from "reading-time";

const post = Astro.props.post;
const { url, title, description, pubDate, image, author, tags } = {
  url: "/blog/" + (post.slug || post.id),
  tags: post.data.tags ?? [],
  title: post.data.title,
  author: post.data.team ?? null,
  image: post.data.image?.url,
  description: post.data.description,
  pubDate: new Date(post.data.pubDate).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "2-digit",
  }),
};

const stats = readingTime(post.body ?? "");

const formattedAuthor = author
  ? author.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase())
  : null;
---

<article class="relative grid grid-cols-1 md:grid-cols-3 gap-8 w-full group">
  <a href={url} title={title} class="absolute inset-0 z-10"> </a>
  <div class="flex flex-col h-full justify-between gap-2">
    <div>
      <div>
        {
          tags.map((tag) => {
            const formattedTag = tag.replace(/-/g, " ");
            return (
              <Text
                tag="p"
                variant="textXS"
                title={tag}
                aria-label={tag}
                class="text-base-600 uppercase font-medium"
              >
                {formattedTag}
              </Text>
            );
          })
        }
      </div>
      <Text
        tag="h3"
        variant="textXL"
        class="mt-8 font-medium font-display text-base-900 group-hover:underline"
      >
        {title}
      </Text>

    </div>

    <div class="flex flex-col gap-y-1 text-base-600">
      {formattedAuthor && <Text tag="p" variant="textSM" class="font-medium">{formattedAuthor}</Text>}
      <Text tag="p" variant="textXS" class="font-medium">
        <time datetime={pubDate}>{pubDate}</time>
        <span aria-hidden="true">·</span>
        {stats.text}
      </Text>
    </div>
  </div>
  {image && (
    <Image
      src={image}
      alt={title}
      width={800}
      height={800}
      loading="eager"
      decoding="async"
      class="object-cover w-full aspect-16/11 md:col-span-2 rounded-xl order-first md:order-last"
    />
  )}
</article>
