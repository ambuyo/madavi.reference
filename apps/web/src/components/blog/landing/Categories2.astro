---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Icons
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";
// Components
import BlogCard5 from "@/components/blog/landing/BlogCard5.astro";
// Data
import { getPostsByCategory } from "@/lib/data";

const categories = [
  { name: "Marketing for Accelerators", slug: "accelerators" },
  { name: "Marketing for Ecommerce", slug: "ecommerce" },
  { name: "Marketing for EdTech", slug: "edtech" },
];

const categoryPosts = await Promise.all(
  categories.map((cat) => getPostsByCategory(cat.slug))
);
---

<section> 
  <Wrapper variant="standard" class="py-8">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-24"
    >
      {
        categories.map((category, i) => (
          <div>
            <Text
              tag="a"
              variant="textXS"
              href={`/blog/cat/${category.slug}`}
              class="flex gap-x-2 text-base-900 justify-between uppercase font-medium"
            >
              {category.name}
              <span class="text-base-600 hover:text-base-900 flex items-center gap-2">
                More stories <ArrowRight class="size-4" />
              </span>
            </Text>
            <div class="flex flex-col mt-2 relative before:absolute after:absolute before:bg-base-950 after:bg-base-950/10 before:top-0 before:left-0 before:h-px before:w-6 after:top-0 after:right-0 after:left-8 after:h-px pt-4">
              {categoryPosts[i].slice(0, 5).map((post) => <BlogCard5 post={post} />)}
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
