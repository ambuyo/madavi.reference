---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Icons
import ArrowRight from "@/components/fundations/icons/ArrowRight.astro";
// Entries
import BlogCard5 from "@/components/blog/landing/BlogCard5.astro";
// Data
import { getPostsByCategory } from "@/lib/data";
const allPosts = await getPostsByCategory("company-updates");
--- 

<div>
  <Text
    tag="a"
    variant="textXS"
    href="/blog/cat/company-updates"
    class="flex gap-x-2 text-base-900 justify-between uppercase font-medium"
  >
    Company Updates<span
      class="text-base-600 hover:text-base-900 flex items-center gap-2 normal-case"
      >More stories <ArrowRight class="size-4" /></span
    >
  </Text>

  <div
    class="relative before:absolute after:absolute before:bg-base-950 after:bg-base-950/10 before:top-0 before:left-0 before:h-px before:w-6 after:top-0 after:right-0 after:left-8 after:h-px pt-4 mt-2"
  >
    <div class="flex flex-col gap-4 border-b border-base-200 divide-y divide-base-200">
      {allPosts.map((post) => <BlogCard5 post={post} />)}
    </div>
  </div>
</div>
