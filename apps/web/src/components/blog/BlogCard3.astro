---
import { Image } from "astro:assets";
import Text from "@/components/fundations/elements/Text.astro";
import readingTime from "reading-time";

const post = Astro.props.post;
const { url, title, pubDate, image, tags } = {
  url: "/blog/" + (post.slug || post.id),
  tags: post.data.tags ?? [],
  title: post.data.title,
  image: post.data.image?.url || null,
  pubDate: new Date(post.data.pubDate).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "2-digit",
  }),
};

const stats = readingTime(post.body ?? "");
---

<article class="relative flex flex-col group">
  <a href={url} title={title} class="absolute inset-0 z-10"> </a>

  {image
    ? <Image src={image} alt={title} width={800} height={800} loading="eager" decoding="async" class="object-cover w-full aspect-12/8 rounded-xl" />
    : <div class="w-full aspect-12/8 rounded-xl bg-base-100" />
  }
  <div class="mt-2">
    <div class="flex items-center gap-x-2 text-base-600">
      <span>
        {
          tags.map((tag: string) => {
            const formattedTag = tag.replace(/-/g, " ");
            return (
              <Text
                tag="p"
                variant="textXS"
                title={tag}
                aria-label={tag}
                class="capitalize"
              >
                {formattedTag}
              </Text>
            );
          })
        }
      </span>
      <span>·</span>
      <Text tag="p" variant="textXS">
        <time datetime={pubDate}>{pubDate}</time>
        <span aria-hidden="true">·</span>
        {stats.text}
      </Text>
    </div>
    <Text
      tag="h3"
      variant="textBase"
      class="flex items-start justify-between gap-4 mt-1 text-base-900 group-hover:underline font-display"
    >
      {title}
    </Text>
  </div>
</article>
