---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const stats = [
  {
    number: "8+",
    label: "Years",
    description: "Spearheading operational transformation across African markets.",
  },
  {
    number: "50+",
    label: "Organizations",
    description: "Guided seamlessly from operational readiness to full deployment.",
  },
  {
    number: "100%",
    label: "Independent",
    description: "Zero vendor partnerships. No software referral commissions. Just honest, objective counsel.",
  },
  {
    number: "90",
    label: "Days Blueprints",
    description: "Actionable, fast-track roadmaps tailored for businesses that cannot wait 18 months.",
  },
];
---

<section id="stats1-section">
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
      <Kicker variant="default">Proven Track Record</Kicker>
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-medium tracking-tight font-display lg:col-span-2 lg:-mt-2"
      >
Stop Investing in AI Tools Your Team Won’t Use.      </Text>
      <div class="lg:col-span-2">
        <Text tag="p" variant="textLG" class="text-base-900 lg:text-pretty">
          Most consultants sell you complex software and leave you to figure out the adoption. We prepare your culture, strategy, and leadership first—ensuring your team actually uses the technology before you spend a shilling on deployment.
        </Text>
        <Text
          tag="p"
          variant="textSM"
          class="text-base-600 mt-4 lg:text-pretty"
        >
          Get your AI roadmap in 4 weeks from $2.5k
        </Text>
        <a
          href="/free-ai-audit"
          class="block mt-6 w-full px-6 py-3 text-sm font-semibold text-white rounded-lg transition-opacity hover:opacity-90 text-center"
          style="background-color: #F97316;"
        >
          Start my AI Audit
        </a>
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-4 gap-4 lg:gap-y-12 mt-12 lg:mt-24"
    >
      {
        stats.map((stat, index) => (
          <div>
            <Text
              tag="p"
              variant="displayXL"
              class="text-base-900  font-display"
              id={`stat-${index}`}
            >
              {stat.number}
            </Text>
            <div class="pt-4 mt-4 border-t  border-base-100">
              <Text
                tag="h3"
                variant="textBase"
                class="text-base-900 font-medium "
              >
                {stat.label}
              </Text>
              <Text tag="p" variant="textSM" class="text-base-600 mt-1">
                {stat.description}
              </Text>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
<script is:inline>
  (function () {
    // Select all elements with IDs starting with "stat-" (the animated number elements)
    const els = Array.from(document.querySelectorAll('[id^="stat-"]'));
    if (!els.length) return;
    // Parse a string value like "500+" into numeric value, suffix, and decimal places
    function parseValue(str) {
      const trimmed = String(str).trim();
      const m = trimmed.replace(/,/g, "").match(/^(-?\d*\.?\d+)(.*)$/);
      if (!m) return { value: 0, suffix: "", decimals: 0 };
      const numPart = m[1];
      const suffix = m[2] || "";
      const decimals = (numPart.split(".")[1] || "").length;
      return { value: parseFloat(numPart), suffix, decimals };
    }
    // Animate a number counting up from 0 to target value with easing
    function animateCount(el, target, suffix, decimals, duration = 1400) {
      const start = performance.now();
      const from = 0;
      // Cubic ease-out function for smooth animation
      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);
      function frame(now) {
        const p = Math.min(1, (now - start) / duration); // Progress 0-1
        const eased = easeOutCubic(p); // Apply easing
        const current = from + (target - from) * eased; // Calculate current value
        // Format display value with proper decimals
        const display =
          decimals > 0
            ? current.toFixed(decimals)
            : Math.round(current).toString();
        el.textContent = `${display}${suffix}`;
        if (p < 1) {
          requestAnimationFrame(frame); // Continue animation
        }
      }
      requestAnimationFrame(frame);
    }
    // IntersectionObserver triggers animation when elements come into view
    const observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target;
          // Prevent re-animation of already animated elements
          if (el.dataset.animated === "1") {
            obs.unobserve(el);
            continue;
          }
          // Parse the target value from the element's text content
          const { value, suffix, decimals } = parseValue(el.textContent || "0");
          // Pre-set to 0 with suffix to avoid flash before animation starts
          el.textContent = `${decimals > 0 ? (0).toFixed(decimals) : "0"}${suffix}`;
          // Start the countup animation
          animateCount(el, value, suffix, decimals);
          // Mark as animated to prevent re-triggering
          el.dataset.animated = "1";
          obs.unobserve(el);
        }
      },
      // Trigger when element is 10% from bottom of viewport
      { root: null, rootMargin: "0px 0px -10% 0px", threshold: 0.2 }
    );
    // Start observing all stat elements
    els.forEach((el) => observer.observe(el));
  })();
</script>
