---
// Assets
import Shield from "@/components/assets/Shield.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import IndustryCard from "@/components/industries/IndustryCard.astro";
// Data
import { getIndustries } from "@/lib/data";
const allIndustries = await getIndustries(2);
--- 
 
<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="p-8 lg:p-12 relative">
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background-image: url('/Section BG.png'); background-size: cover; background-position: center; opacity: 0.5;"></div>
      <div class="relative z-10 max-w-xl">
        <Kicker variant="default">SECTOR CLARITY</Kicker>
        <Text
          tag="h2"
          variant="displayMD"
          class="text-base-900 text-balance font-display lg:mt-8"
        >
Different Obstacles. One Clear Methodology.        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-700 lg:text-balance mt-4"
        >
Our AI Framework methodology works across sectors because cultural readiness, strategic alignment, and decision infrastructure are universal challenges—even when industry constraints differ.
        </Text>
      </div>
      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-3 mt-12 gap-2">
        {
          allIndustries
            .map((industry) => (
              <IndustryCard industry={industry} titleOnly={true} />
            ))
        }
        <div
          class="bg-accent-400 p-8 flex flex-col h-full justify-between gap-8"
        >
          <div>  
            <Shield class="h-8 text-white" />
            <Text
              tag="h3"
              variant="displaySM"
              class="text-base text-white font-display font-medium mt-24"
            >
              Ready to get started?
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="text-white font-medium mt-2"
            >
              Get in touch with us to learn more about our services and how we
              can help you.
            </Text>
          </div>
          <Button
            size="sm"
            variant="muted"
            isLink={true}
            href="/industries"
            class="w-fit"
          >
            Explore All Industries
          </Button>
        </div>
      </div>
    </div>
  </Wrapper>
</section>
