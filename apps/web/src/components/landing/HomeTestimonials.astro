---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Sanity
import { client } from "@/lib/sanity/client";

const logos = await client.fetch(`*[_type == "clientLogo"] | order(order asc) {
  _id,
  company,
  logo {
    asset -> {
      url
    },
    alt
  },
  url
}`);
---

<style>
  .logo-scroll {
    animation: logo-scroll 23s linear infinite;
  }
  .logo-scroll:hover {
    animation-play-state: paused;
  }
  @keyframes logo-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="bg-accent-950 relative overflow-hidden">
  <Wrapper
    variant="standard"
    class="py-12 lg:py-24 lg:border-x lg:border-white/10"
  >
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div>
        <div class="relative overflow-hidden rounded-sm bg-black" style="aspect-ratio: 4/5;">
          <iframe
            src="https://www.youtube.com/embed/qMn6FWyjhsk"
            title="Client testimonial"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="absolute inset-0 w-full h-full border-0"
          ></iframe>
        </div>
        <blockquote class="mt-3 text-base-300 text-sm leading-relaxed font-medium border-l-2 border-accent-400 pl-3">
          "Working with Madavi Agency transformed our online presence — the results speak for themselves."
          <footer class="mt-1 text-base-500 text-xs not-italic">— Allan Mzungu</footer>
        </blockquote>
      </div>
      <div class="lg:col-span-2 text-pretty">
        <Kicker class="text-base-400 mb-4">PROVEN ADOPTION</Kicker>
        <Text
          tag="h2"
          variant="displayLG"
          class="text-white font-medium tracking-tight"
        >
          See how partners, CEOs, and directors across enterprises have bypassed tech hype to
          <span class="text-accent-400">
             eliminate operational waste, and achieve genuine workforce adoption.
          </span>
        </Text>
        <Text tag="p" variant="textLG" class="text-base-400 mt-4">
Join the 50+ organizations that prioritized their people over the platform and secured a clear, long-term return on their technology investments.
        </Text>
        {logos.length > 0 && (
          <div class="mt-12">
            <div class="flex justify-end mb-3">
              <a
                href="/clients"
                class="inline-flex items-center gap-2 text-base-400 text-sm font-medium hover:underline underline-offset-4 transition-colors hover:text-white group"
              >
                Our Clients
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
            <div class="overflow-hidden bg-white py-7 rounded-sm" style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
              <div class="flex gap-12 items-center logo-scroll">
                {[...logos, ...logos].map((logo) => (
                  <div class="shrink-0 w-32 h-14 flex items-center justify-center">
                    <img
                      src={logo.logo?.asset?.url}
                      alt={logo.logo?.alt || logo.company}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-contain grayscale opacity-50 hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                    />
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </Wrapper>
</section>
