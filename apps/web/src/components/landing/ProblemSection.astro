---
import { Image } from "astro:assets";
import talk from "@/images/assets/talk.png";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const outcomes = [
  {
    title: "Team Buy-In",
    description: "before software installation.",
  },
  {
    title: "Executive Alignment",
    description: "before shortlisting vendors.",
  },
  {
    title: "Internal Capability",
    description: "so they aren't trapped in endless reliance on external IT agencies.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-8 p-8 lg:p-12 relative">
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background-image: url('/Section BG.png'); background-size: cover; background-position: center; opacity: 0.7;"></div>
      <Image
        src={talk}
        alt="AI implementation failure"
        width={800}
        height={1440}
        loading="lazy"
        decoding="async"
        class="relative z-10 size-full object-cover object-center aspect-square"
      />
      <div class="relative z-10 flex flex-col">
        <div>
          <Kicker variant="default">Why Couture & Enterprise AI Initiatives Fail</Kicker>
          <Text
            tag="h2"
            variant="displayMD"
            class="text-base-950 text-balance font-medium tracking-tight font-display mt-8"
          >
            AI Fails Because Businesses Skip the Human Work.
          </Text>
          <Text tag="p" variant="textBase" class="text-base-700 mt-4 text-pretty">
            AI implementation doesn't fail because the software breaks.
          </Text>
          <Text tag="p" variant="textBase" class="text-base-700 mt-3 text-pretty">
            It fails because leadership jumps straight to installation—ignoring staff friction, workflow displacement, and communication gaps.
          </Text>
          <Text tag="p" variant="textBase" class="text-base-700 mt-3 text-pretty">
            After monitoring this across dozens of organizations, we know that successful companies don't have massive tech budgets. They succeed because they achieve:
          </Text>
        </div>
        <div class="flex flex-col gap-6 mt-10">
          {
            outcomes.map((item) => (
              <div class="flex flex-col">
                <Text tag="span" variant="textBase" class="text-base-900 font-semibold font-display">
                  {item.title}
                </Text>
                <Text tag="span" variant="textBase" class="text-base-600">
                  {item.description}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>

</section>
