---
// Fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Contact Components
import ContactInfo from "@/components/contact/ContactInfo.astro";
import { ContactFormReact } from "@/components/contact/ContactFormReact";
---

<section >
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid lg:grid-cols-3 gap-8">
      <ContactInfo />
      <div class="lg:col-span-2" style="border-radius: 25px">
        <ContactFormReact client:load />
      </div>
    </div>
  </Wrapper>
</section>
