---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Review {
  author: string;
  initials: string;
  avatarBg: string;
  rating: number;
  text: string;
  date: string;
  ownerResponse?: string;
  ownerResponseDate?: string;
}

// Replace with actual Madavi Agency Google reviews
const reviews: Review[] = [
  {
    author: "Sarah M.",
    initials: "SM",
    avatarBg: "#4285F4",
    rating: 5,
    text: "Madavi Agency completely transformed our digital marketing strategy. The AI-powered workflows they built saved us hours every week and our lead quality improved dramatically within the first month.",
    date: "1 week ago",
    ownerResponse: "Thank you so much, Sarah! It's been a pleasure working with your team.",
    ownerResponseDate: "5 days ago",
  },
  {
    author: "James Odhiambo",
    initials: "JO",
    avatarBg: "#EA4335",
    rating: 5,
    text: "Exceptional work. They built a custom AI automation system for our law firm that handles intake, scheduling, and document drafting. The ROI was clear within weeks.",
    date: "2 weeks ago",
    ownerResponse: "We're thrilled to hear that, James! Helping your firm run efficiently is exactly what we set out to do.",
    ownerResponseDate: "10 days ago",
  },
  {
    author: "Priya K.",
    initials: "PK",
    avatarBg: "#34A853",
    rating: 5,
    text: "Outstanding service. The team at Madavi really listens and delivers. Our content pipeline is now fully automated and our organic traffic has doubled.",
    date: "3 weeks ago",
  },
  {
    author: "Daniel Waweru",
    initials: "DW",
    avatarBg: "#FBBC05",
    rating: 5,
    text: "Highly recommend. They understood our healthcare compliance requirements and built AI workflows that actually work within our constraints. Very professional team.",
    date: "1 month ago",
  },
  {
    author: "Amara N.",
    initials: "AN",
    avatarBg: "#9C27B0",
    rating: 5,
    text: "We hired Madavi to revamp our SEO and marketing automation. Within 90 days our inbound leads tripled. The team is knowledgeable, responsive, and genuinely cares about results.",
    date: "1 month ago",
  },
  {
    author: "Kevin Otieno",
    initials: "KO",
    avatarBg: "#FF5722",
    rating: 5,
    text: "Game-changing work for our non-profit. Madavi helped us implement AI tools that amplified our outreach without adding headcount. Couldn't be happier.",
    date: "2 months ago",
  },
  {
    author: "Lisa Chen",
    initials: "LC",
    avatarBg: "#00BCD4",
    rating: 5,
    text: "Top-tier agency. They don't just sell software — they make sure your whole team actually adopts it. That human-first approach made all the difference for us.",
    date: "2 months ago",
  },
  {
    author: "Marcus T.",
    initials: "MT",
    avatarBg: "#607D8B",
    rating: 5,
    text: "Working with Madavi was a seamless experience from start to finish. The AI audit they provided uncovered inefficiencies we didn't even know existed. Results speak for themselves.",
    date: "3 months ago",
  },
];

const [first, second, ...rest] = reviews;

function renderStars(rating: number) {
  return Array.from({ length: 5 }, (_, i) => i < rating);
}
---

<section style="background-color: #FEFCF4;" class="relative overflow-hidden">
  <Wrapper variant="standard" class="py-12 lg:py-24 lg:border-x lg:border-base-200">
    <Kicker class="text-base-500 mb-4">GOOGLE REVIEWS</Kicker>
    <Text
      tag="h2"
      variant="displayLG"
      class="text-base-900 font-medium tracking-tight max-w-2xl mb-12"
    >
      What Our Clients Say on Google
    </Text>

    <!-- Top 2: most recent, large -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      {[first, second].map((review) => (
        <div class="bg-white rounded-xl shadow-sm border border-base-100 p-6 flex flex-col gap-4">
          <div class="flex gap-0.5">
            {renderStars(review.rating).map((filled) => (
              <svg class={`w-5 h-5 ${filled ? "text-yellow-400" : "text-base-200"}`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <Text tag="p" variant="textLG" class="text-base-900 font-medium leading-snug flex-1">
            {review.text}
          </Text>
          <div class="flex items-center justify-between mt-auto pt-2 border-t border-base-100">
            <div class="flex items-center gap-3">
              <div
                class="w-9 h-9 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0"
                style={`background-color: ${review.avatarBg};`}
              >
                {review.initials}
              </div>
              <div>
                <p class="text-sm font-semibold text-base-900">{review.author}</p>
                <p class="text-xs text-base-400">{review.date}</p>
              </div>
            </div>
            <!-- Google logo -->
            <svg class="h-5 w-auto" viewBox="0 0 74 24" aria-label="Google" role="img">
              <path d="M9.24 8.19v2.46h5.88c-.18 1.38-.64 2.39-1.34 3.1-.86.86-2.2 1.8-4.54 1.8-3.62 0-6.45-2.92-6.45-6.54s2.83-6.54 6.45-6.54c1.95 0 3.38.77 4.43 1.76L15.4 2.5C13.94 1.08 11.98 0 9.24 0 4.28 0 .11 4.04.11 9s4.17 9 9.13 9c2.68 0 4.7-.88 6.28-2.52 1.62-1.62 2.13-3.91 2.13-5.75 0-.57-.04-1.1-.13-1.54H9.24z" fill="#4285F4"/>
              <path d="M25 6.19c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52z" fill="#EA4335"/>
              <path d="M53.58 7.49h-.09c-.57-.68-1.67-1.3-3.06-1.3C47.53 6.19 45 8.72 45 12c0 3.26 2.53 5.81 5.43 5.81 1.39 0 2.49-.62 3.06-1.32h.09v.81c0 2.22-1.19 3.41-3.1 3.41-1.56 0-2.53-1.12-2.93-2.07l-2.22.92c.64 1.54 2.33 3.43 5.15 3.43 2.99 0 5.52-1.76 5.52-6.05V6.49h-2.42v1zm-2.93 8.03c-1.76 0-3.1-1.5-3.1-3.52 0-2.05 1.34-3.52 3.1-3.52 1.74 0 3.1 1.5 3.1 3.54-.01 2.03-1.36 3.5-3.1 3.5z" fill="#4285F4"/>
              <path d="M38 6.19c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52z" fill="#FBBC05"/>
              <path d="M58.5 0h2.55v17.73H58.5z" fill="#34A853"/>
              <path d="M68.08 15.52c-1.3 0-2.22-.59-2.82-1.76l7.77-3.21-.26-.66c-.48-1.3-1.96-3.7-4.97-3.7-2.99 0-5.48 2.35-5.48 5.81 0 3.26 2.46 5.81 5.76 5.81 2.66 0 4.2-1.63 4.84-2.57l-1.98-1.32c-.66.96-1.56 1.6-2.86 1.6zm-.18-7.15c1.03 0 1.91.53 2.2 1.28l-5.25 2.17c0-2.44 1.73-3.45 3.05-3.45z" fill="#EA4335"/>
            </svg>
          </div>
          {review.ownerResponse && (
            <div class="bg-base-50 rounded-lg p-4 text-sm text-base-600">
              <p class="font-semibold text-base-700 mb-1">
                Response from the owner: <span class="font-normal text-base-400">{review.ownerResponseDate}</span>
              </p>
              <p>{review.ownerResponse}</p>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Remaining reviews: 3-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {rest.map((review) => (
        <div class="bg-white rounded-xl shadow-sm border border-base-100 p-5 flex flex-col gap-3">
          <div class="flex gap-0.5">
            {renderStars(review.rating).map((filled) => (
              <svg class={`w-4 h-4 ${filled ? "text-yellow-400" : "text-base-200"}`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <Text tag="p" variant="textBase" class="text-base-700 leading-snug flex-1">
            {review.text}
          </Text>
          <div class="flex items-center justify-between mt-auto pt-2 border-t border-base-100">
            <div class="flex items-center gap-2">
              <div
                class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0"
                style={`background-color: ${review.avatarBg};`}
              >
                {review.initials}
              </div>
              <div>
                <p class="text-xs font-semibold text-base-900">{review.author}</p>
                <p class="text-xs text-base-400">{review.date}</p>
              </div>
            </div>
            <!-- Google logo -->
            <svg class="h-4 w-auto" viewBox="0 0 74 24" aria-label="Google" role="img">
              <path d="M9.24 8.19v2.46h5.88c-.18 1.38-.64 2.39-1.34 3.1-.86.86-2.2 1.8-4.54 1.8-3.62 0-6.45-2.92-6.45-6.54s2.83-6.54 6.45-6.54c1.95 0 3.38.77 4.43 1.76L15.4 2.5C13.94 1.08 11.98 0 9.24 0 4.28 0 .11 4.04.11 9s4.17 9 9.13 9c2.68 0 4.7-.88 6.28-2.52 1.62-1.62 2.13-3.91 2.13-5.75 0-.57-.04-1.1-.13-1.54H9.24z" fill="#4285F4"/>
              <path d="M25 6.19c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52z" fill="#EA4335"/>
              <path d="M53.58 7.49h-.09c-.57-.68-1.67-1.3-3.06-1.3C47.53 6.19 45 8.72 45 12c0 3.26 2.53 5.81 5.43 5.81 1.39 0 2.49-.62 3.06-1.32h.09v.81c0 2.22-1.19 3.41-3.1 3.41-1.56 0-2.53-1.12-2.93-2.07l-2.22.92c.64 1.54 2.33 3.43 5.15 3.43 2.99 0 5.52-1.76 5.52-6.05V6.49h-2.42v1zm-2.93 8.03c-1.76 0-3.1-1.5-3.1-3.52 0-2.05 1.34-3.52 3.1-3.52 1.74 0 3.1 1.5 3.1 3.54-.01 2.03-1.36 3.5-3.1 3.5z" fill="#4285F4"/>
              <path d="M38 6.19c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52z" fill="#FBBC05"/>
              <path d="M58.5 0h2.55v17.73H58.5z" fill="#34A853"/>
              <path d="M68.08 15.52c-1.3 0-2.22-.59-2.82-1.76l7.77-3.21-.26-.66c-.48-1.3-1.96-3.7-4.97-3.7-2.99 0-5.48 2.35-5.48 5.81 0 3.26 2.46 5.81 5.76 5.81 2.66 0 4.2-1.63 4.84-2.57l-1.98-1.32c-.66.96-1.56 1.6-2.86 1.6zm-.18-7.15c1.03 0 1.91.53 2.2 1.28l-5.25 2.17c0-2.44 1.73-3.45 3.05-3.45z" fill="#EA4335"/>
            </svg>
          </div>
          {review.ownerResponse && (
            <div class="bg-base-50 rounded-lg p-3 text-xs text-base-600">
              <p class="font-semibold text-base-700 mb-0.5">
                Response from the owner: <span class="font-normal text-base-400">{review.ownerResponseDate}</span>
              </p>
              <p>{review.ownerResponse}</p>
            </div>
          )}
        </div>
      ))}
    </div>
  </Wrapper>
</section>
