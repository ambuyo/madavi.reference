---
// Assets
import Shield from "@/components/assets/Shield.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
// Data
import { getSolutions } from "@/lib/sanity/reports";

// Fetch solutions
const solutionDescriptions: Record<string, string> = {
  kuzafy: "Automated WhatsApp Commerce",
};

const solutions = await getSolutions();
const solutionLinks = solutions.map((solution) => ({
  href: `/solutions/${solution.slug.current}`,
  label: solution.name,
  description: solutionDescriptions[solution.slug.current] ?? "",
}));

// Megamenu sections
const megamenuSections = [
  {
    title: "Solutions",
    href: "/solutions",
    links: solutionLinks,
  },
  {
    title: "The AI Studio",
    href: "/ai-studio",
    links: [
      {
        href: "/capabilities/ai-readiness",
        label: "AI Readiness Assessment",
        description: "Benchmark your org's AI maturity",
      },
      {
        href: "/capabilities/executive-advisory",
        label: "Executive Advisory",
        description: "On-call strategic AI counsel",
      },
      {
        href: "/capabilities/leadership-cohort",
        label: "Leadership AI Fluency",
        description: "Train leaders to lead in an AI world",
      },
      {
        href: "/capabilities/keynotes-licensing",
        label: "Keynotes & Licensing",
        description: "Inspire your teams and audiences",
      },
      {
        href: "/capabilities/ai-agent-development",
        label: "AI Agent Development",
        description: "Agents that act, not just answer",
      },
    ],
  },
  {
    title: "The IMC Agency",
    href: "/the-imc-agency",
    links: [
      {
        href: "/capabilities/brand-strategy",
        label: "Brand Strategy",
        description: "Define your position and purpose",
      },
      {
        href: "/capabilities/brand-communication",
        label: "Brand Communications",
        description: "Copy that resonates and converts",
      },
      {
        href: "/capabilities/brand-management",
        label: "Brand Management",
        description: "Grow your brand equity",
      },
      {
        href: "/capabilities/website-design",
        label: "Website Design",
        description: "Websites built for growth",
      },
      {
        href: "/capabilities/seo-services",
        label: "SEO",
        description: "Rank higher, get found organically",
      },
    ],
  },
  {
    title: "Our Industries",
    href: "/industries",
    links: [
      {
        href: "/industries/legal",
        label: "Legal Services",
        description: "AI for law firms and legal teams",
      },
      {
        href: "/industries/healthcare",
        label: "Healthcare",
        description: "Compliant AI for clinical ops",
      },
      {
        href: "/industries/nonprofits",
        label: "Non Profits",
        description: "Amplify impact with smarter tools",
      },
      {
        href: "/industries/retail",
        label: "Ecommerce & Retail",
        description: "Convert more, retain longer",
      },
      {
        href: "/industries/professional-services",
        label: "Professional Services",
        description: "Scale expertise efficiently with AI",
      },
      {
        href: "/industries/real-estate",
        label: "Real Estate",
        description: "Smarter client acquisition and ops",
      },
    ],
  },
];
---

<div
  id="megamenu"
  class="hidden fixed left-0 right-0 top-[73px] z-40 md:max-h-none max-h-[calc(100vh-73px)] overflow-y-auto"
  style="background-color: #FEFCF4;"
>
  <div class="flex justify-center">
    <div class="w-full max-w-7xl px-12 py-12">
      <div class="grid grid-cols-2 gap-y-8 lg:grid-cols-5 p-0">

        <!-- Col 1: CTA panel -->
        <div class="p-8 bg-accent-400 flex flex-col h-full justify-between gap-12 lg:gap-18 col-span-full lg:col-span-1">
          <div>
            <Shield class="h-6 text-white" />
            <Text
              tag="h3"
              variant="displaySM"
              class="text-base text-white mt-8 font-display font-medium"
            >
              Get in touch
            </Text>
            <Text tag="p" variant="textSM" class="text-white font-medium mt-2">
              Get in touch with us to learn more about our services and how we can help you.
            </Text>
          </div>
          <Button variant="muted" size="xs" isLink={true} href="/get-a-proposal" class="w-fit">
            Contact Us
          </Button>
        </div>

        <!-- Cols 2–5: sections -->
        {megamenuSections.map((section) => (
          <div class="px-6 flex flex-col">
            <!-- Pill header -->
            <a
              href={section.href}
              class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full font-medium hover:opacity-80 transition-opacity mb-8 w-fit"
              style="background-color: #C5E39C; font-family: 'Tiempos', serif; font-size: 15px; color: #1B1B1B;"
            >
              {section.title}
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>

            <!-- Links with dividers -->
            <ul class="divide-y divide-[#E97451]/40">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="group flex flex-col py-3 hover:opacity-70 transition-opacity"
                  >
                    <span
                      class="font-semibold leading-snug"
                      style="font-family: 'Tiempos', serif; font-size: 15px; color: #1B1B1B;"
                    >
                      {link.label}
                    </span>
                    {link.description && (
                      <span
                        class="mt-0.5 leading-snug"
                        style="font-family: 'DM Sans', sans-serif; font-size: 12px; color: #7A8189;"
                      >
                        {link.description}
                      </span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <!-- Footer -->
        <div
          class="border-t pt-4 mt-4 col-span-full flex flex-col lg:flex-row gap-4 lg:items-center lg:justify-between"
          style="border-color: #E97451;"
        >
          <div class="flex flex-wrap gap-4 items-center">
            <a
              href="tel:+254718735565"
              class="text-xs hover:text-accent-500 transition-colors"
              style="color: #7A8189;"
            >
              +254 (718) 735-565
            </a>
            <span class="hidden md:flex" style="color: #E97451;">|</span>
            <address class="not-italic text-xs" style="color: #7A8189;">
              2595, 1007 N Orange St. 4th Floor, DE, Wilmington, USA
            </address>
          </div>
          <div class="flex flex-wrap gap-4 items-center order-first lg:order-none">
            <a href="#_" class="text-xs hover:text-accent-500 transition-colors" style="color: #7A8189;">X</a>
            <a href="#_" class="text-xs hover:text-accent-500 transition-colors" style="color: #7A8189;">LinkedIn</a>
            <a href="#_" class="text-xs hover:text-accent-500 transition-colors" style="color: #7A8189;">Email</a>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
