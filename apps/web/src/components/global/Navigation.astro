---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Search from "@/components/global/Search.astro";
import MobileNav from "@/components/global/MobileNav.astro";
import Megamenu from "@/components/global/Megamenu.astro";
import ResourcesMegamenu from "@/components/global/ResourcesMegamenu.astro";

interface Props {
  variant?: "default" | "transparent";
}

const { variant = "default" } = Astro.props;

// Navigation links
const navLinks = [
  { label: "Capabilities", href: "/capabilities", hasMegamenu: true },
  { label: "Our Work", href: "/our-work" },
  { label: "Our Approach", href: "/our-approach" },
  { label: "Resources", href: "/resources", hasMegamenu: true },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const headerBaseClass = "fixed inset-x-0 top-0 z-50 transition-all duration-300";
const headerClass = variant === "transparent"
  ? "bg-transparent [&.scrolled]:bg-white [&.scrolled]:border-b [&.scrolled]:border-base-200 [&.scrolled]:shadow-sm"
  : "bg-white border-b border-base-200";
---

<header class={`${headerBaseClass} ${headerClass}`} data-navbar-variant={variant}>
  <Wrapper variant="standard" class="py-4">
    <div class="flex items-center justify-between gap-4">
      <!-- Logo -->
      <a
        href="/"
        class={`flex items-center gap-3 shrink-0 transition-colors ${variant === "transparent" ? "text-white [.scrolled_&]:text-base-900" : "text-base-900"}`}
      >
        <Logo
          variant={variant === "transparent" ? "light" : "dark"}
          class="h-13 w-auto [.scrolled_&]:hidden"
          id="logo-light"
        />

        <Logo
          variant="dark"
          class={`h-12 w-auto ${variant === "transparent" ? "hidden [.scrolled_&]:block" : "hidden"}`}
          id="logo-dark"
        />
      </a>
      <!-- Pill nav (transparent) / flat nav (default or scrolled) -->
      <nav
        class={`hidden lg:flex items-center transition-all duration-300 ${
          variant === "transparent"
            ? "gap-0.5 rounded-full border border-white/20 bg-white/10 backdrop-blur-md px-2 py-1.5 shadow-sm [.scrolled_&]:gap-8 [.scrolled_&]:rounded-none [.scrolled_&]:border-transparent [.scrolled_&]:bg-transparent [.scrolled_&]:backdrop-blur-none [.scrolled_&]:px-0 [.scrolled_&]:py-0 [.scrolled_&]:shadow-none"
            : "gap-8"
        }`}
        aria-label="Primary"
      >
        {
          navLinks.map((link) => {
            const hasMegamenu = link.hasMegamenu;
            const linkClass = variant === "transparent"
              ? "px-4 py-2 rounded-full text-white/90 hover:text-white hover:bg-white/15 [.scrolled_&]:px-0 [.scrolled_&]:py-0 [.scrolled_&]:rounded-none [.scrolled_&]:text-base-700 [.scrolled_&]:hover:text-base-950 [.scrolled_&]:hover:bg-transparent"
              : "text-base-700 hover:text-base-950";
            return (
              <a
                href={link.href}
                data-megamenu={hasMegamenu ? link.label.toLowerCase() : undefined}
                class={`text-sm font-medium transition-colors ${linkClass} ${hasMegamenu ? "has-megamenu" : ""}`}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
      <!-- Actions -->
      <div class="flex items-center gap-2 shrink-0">
        <Search variant={variant} />
        {variant === "transparent" ? (
          <>
            <Button isLink size="base" variant="orange" href="/contact" class="hidden lg:flex rounded-[15px] [.scrolled_&]:!hidden">
              Get My AI Audit
            </Button>
            <Button isLink size="base" variant="orange" href="/contact" class="hidden rounded-[15px] [.scrolled_&]:!flex">
              Get My AI Audit
            </Button>
          </>
        ) : (
          <Button isLink size="base" variant="orange" href="/contact" class="hidden lg:flex rounded-[15px]">
            Get My AI Audit
          </Button>
        )}
        <MobileNav links={navLinks} variant={variant} />
      </div>
    </div>
  </Wrapper>
  <Megamenu />
  <ResourcesMegamenu />
</header>

<script is:inline>
  // Handle navbar scroll detection
  function handleNavbarScroll() {
    const header = document.querySelector("header[data-navbar-variant]");
    if (!header) return;

    const variant = header.getAttribute("data-navbar-variant");
    if (variant !== "transparent") return;

    function updateNavbarStyle() {
      const isScrolled = window.scrollY > 10;
      if (isScrolled) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
    }

    window.addEventListener("scroll", updateNavbarStyle, { passive: true });
    updateNavbarStyle();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", handleNavbarScroll);
  } else {
    handleNavbarScroll();
  }

  document.addEventListener("DOMContentLoaded", function() {
    const header = document.querySelector("header");
    if (!header) return;

    const capabilitiesLink = header.querySelector('[data-megamenu="capabilities"]');
    const resourcesLink = header.querySelector('[data-megamenu="resources"]');
    const megamenu = header.querySelector("#megamenu");
    const resourcesMegamenu = header.querySelector("#resources-megamenu");

    let hideTimer = null;

    const cancelHide = () => {
      clearTimeout(hideTimer);
      hideTimer = null;
    };

    const scheduleHide = () => {
      cancelHide();
      hideTimer = setTimeout(() => {
        megamenu?.classList.add("hidden");
        resourcesMegamenu?.classList.add("hidden");
      }, 120);
    };

    const showCapabilitiesMenu = () => {
      cancelHide();
      megamenu?.classList.remove("hidden");
      resourcesMegamenu?.classList.add("hidden");
    };

    const showResourcesMenu = () => {
      cancelHide();
      resourcesMegamenu?.classList.remove("hidden");
      megamenu?.classList.add("hidden");
    };

    capabilitiesLink?.addEventListener("mouseenter", showCapabilitiesMenu);
    capabilitiesLink?.addEventListener("mouseleave", scheduleHide);

    resourcesLink?.addEventListener("mouseenter", showResourcesMenu);
    resourcesLink?.addEventListener("mouseleave", scheduleHide);

    megamenu?.addEventListener("mouseenter", cancelHide);
    megamenu?.addEventListener("mouseleave", scheduleHide);

    resourcesMegamenu?.addEventListener("mouseenter", cancelHide);
    resourcesMegamenu?.addEventListener("mouseleave", scheduleHide);
  });
</script>
