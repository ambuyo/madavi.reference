---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Data
import { getPosts, getOurWork } from "@/lib/data";
import { getReports } from "@/lib/sanity/reports";

// Fetch latest items from different sources
const allPosts = await getPosts();
const allReports = await getReports();
const allOurWork = await getOurWork();

// Get latest report
const latestReport = allReports.sort((a, b) => {
  const dateA = new Date(a.publicationDate).getTime();
  const dateB = new Date(b.publicationDate).getTime();
  return dateB - dateA;
})[0];

// Get latest Our Work (from Sanity case studies) - sorted by Year
const latestOurWork = allOurWork.sort((a, b) => {
  const yearA = parseInt(String(a.data.year)) || 0;
  const yearB = parseInt(String(b.data.year)) || 0;
  return yearB - yearA;
})[0];

// Helper function to get image URL
const getImageUrl = (image: any) => {
  if (typeof image === "string") return image;
  return image?.src || image?.url || "";
};

// Get latest AI Studio article
const latestAIStudio = allPosts
  ?.filter(post => post.data.categories?.[0]?.name?.toLowerCase().includes("ai studio"))
  ?.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())?.[0];

// Get latest Growth Marketing article
const latestGrowthMarketing = allPosts
  ?.filter(post => post.data.categories?.[0]?.name?.toLowerCase().includes("growth marketing"))
  ?.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())?.[0];

// Featured items for Latest Media - 2x2 standardized grid
const mediaItems = [
  latestReport && {
    image: latestReport.reportCoverImage?.asset?.url || "",
    category: "Reports",
    title: latestReport.name,
    href: `/resources/reports/${latestReport.slug.current}`,
  },
  latestOurWork && {
    image: getImageUrl(latestOurWork.data.image),
    category: "Our Work",
    title: latestOurWork.data.client || latestOurWork.data.tagline || "Untitled Work",
    href: `/our-work/${latestOurWork.slug}`,
  },
  latestAIStudio && {
    image: getImageUrl(latestAIStudio.data.image),
    category: "AI Studio",
    title: latestAIStudio.data.title,
    href: `/blog/${latestAIStudio.slug}`,
  },
  latestGrowthMarketing && {
    image: getImageUrl(latestGrowthMarketing.data.image),
    category: "Growth Marketing",
    title: latestGrowthMarketing.data.title,
    href: `/blog/${latestGrowthMarketing.slug}`,
  },
].filter((item): item is any => !!item);

// Resources sections
const resourcesSections = [
  {
    title: "Our resources",
    href: "/resources",
    links: [
      { href: "/resources/events", label: "Events & Summits", description: "Our upcoming events and recordings", icon: "🎤" },
      { href: "/resources/customer-stories", label: "Customer Stories", description: "Behind the successful partnerships", icon: "👥" },
      { href: "/resources/our-clients", label: "Our Clients", description: "Brands we have worked with", icon: "🤝" },
      { href: "/resources/reports", label: "Reports", description: "Data for smarter decisions", icon: "📊" },
      { href: "/blog", label: "Blog", description: "Long-form you can learn from", icon: "💬" },
      { href: "/resources/faqs", label: "FAQs", description: "Answers to common questions", icon: "❓" },
    ],
  },
];
---

<div
  id="resources-megamenu"
  class="hidden fixed left-0 right-0 top-[73px] z-40 md:max-h-none max-h-[calc(100vh-73px)] overflow-y-auto"
  style="background-color: #FAF9F6;"
>
  <div class="flex justify-center">
    <div class="w-full max-w-7xl px-12 py-12">
      <div class="grid grid-cols-3 gap-12 divide-x" style="border-color: #E8E6E1;">
        {/* Left Column - 1/3 */}
        <div class="px-0">
          <Text
            tag="h3"
            variant="textSM"
            class="uppercase mb-8 lg:mb-12"
            style="color: #36454F;"
          >
            Our resources
          </Text>
          <ul class="space-y-0">
            {resourcesSections[0].links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="group flex items-start justify-between gap-4 py-2"
                >
                  <div>
                    <div
                      class="group-hover:text-accent-400 transition-colors"
                      style="color: #36454F; font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600; line-height: 1.2;"
                    >
                      {link.label}
                    </div>
                    <div
                      style="color: #7A8189; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 400; line-height: 1.4;"
                    >
                      {link.description}
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>

        {/* Right Column - 2/3 */}
        <div class="col-span-2 px-6">
          <Text
            tag="h3"
            variant="textSM"
            class="uppercase mb-8"
            style="color: #36454F;"
          >
            Latest Media
          </Text>
          {/* 2x2 Standardized Grid */}
          <div class="grid grid-cols-2 gap-6">
            {mediaItems.map((item) => (
              <a href={item.href} class="group">
                {/* Featured Image - 50% smaller */}
                {item.image && (
                  <div class="mb-4 rounded-lg overflow-hidden bg-base-100" style="aspect-ratio: 16/9; max-width: 68%;">
                    <img
                      src={item.image}
                      alt={item.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}

                {/* Category */}
                <Text
                  tag="p"
                  variant="textXS"
                  class="uppercase font-medium mb-2"
                  style="color: #1EB49C;"
                >
                  {item.category}
                </Text>

                {/* Title */}
                <Text
                  tag="h4"
                  variant="textBase"
                  class="font-semibold group-hover:text-accent-400 transition-colors"
                  style="color: #36454F;"
                >
                  {item.title}
                </Text>
              </a>
            ))}
          </div>
        </div>
      </div>

      {/* Footer */}
      <div
        class="border-t pt-4 mt-8 flex flex-col lg:flex-row gap-4 lg:items-center lg:justify-between"
        style="border-color: #E8E6E1;"
      >
        <div class="flex flex-wrap gap-4 items-center">
          <a
            href="tel:+1-555-123-4567"
            class="text-xs hover:text-accent-400 transition-colors"
            style="color: #7A8189;"
          >
            +254 (718) 735-565
          </a>
          <span class="hidden md:flex" style="color: #D6D3CC;">|</span>
          <address class="not-italic text-xs" style="color: #7A8189;">
            2595, 1007 N Orange St. 4th Floor, DE, Wilmington, USA
          </address>
        </div>
        <div class="flex flex-wrap gap-4 items-center order-first lg:order-none">
          <a
            href="#_"
            class="text-xs hover:text-accent-400 transition-colors"
            style="color: #7A8189;"
          >
            X
          </a>
          <a
            href="#_"
            class="text-xs hover:text-accent-400 transition-colors"
            style="color: #7A8189;"
          >
            LinkedIn
          </a>
          <a
            href="#_"
            class="text-xs hover:text-accent-400 transition-colors"
            style="color: #7A8189;"
          >
            Email
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
