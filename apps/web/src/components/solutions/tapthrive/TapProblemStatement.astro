---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const problems = [
  {
    label: "The Timing Problem",
    quote: "A happy customer walks out your door. Two hours later they're in traffic, cooking dinner, thinking about tomorrow. The motivation to review is gone — even if the experience was great.",
    stat: "4.2",
    statLabel: "avg. rating lost from missed reviews",
    icon: "⏱️",
    accent: "#dff0ed",
  },
  {
    label: "The Friction Problem",
    quote: "Finding your Google Business page, tapping the stars, writing something — it takes two minutes but feels like ten. Most people don't bother unless someone makes it effortless, right now.",
    stat: "68%",
    statLabel: "of customers complete reviews when the path is instant",
    icon: "📱",
    accent: "#dde8f5",
  },
  {
    label: "The Review Imbalance",
    quote: "Disappointed customers find review platforms on their own. Happy ones need to be guided. Without a system, your rating tells the story of your worst days, not your best ones.",
    stat: "3×",
    statLabel: "more likely — unhappy customers vs happy ones to review",
    icon: "📣",
    accent: "#f0ead8",
  },
  {
    label: "The Visibility Problem",
    quote: "Reviews directly affect your local search ranking. More reviews, higher rating, more visibility. Every week without a review system is a week you're handing ground to competitors who have one.",
    stat: "+9%",
    statLabel: "revenue lift from one extra star on Google",
    icon: "🔍",
    accent: "#e8e8f0",
  },
];

const stats = [
  { value: "7/10", label: "customers will review when asked the right way" },
  { value: "88%", label: "trust online reviews as much as personal recommendations" },
  { value: "+9%", label: "revenue lift from one extra star on Google" },
  { value: "72 hrs", label: "to go live with TapThrive after sign-up" },
];
---

<section id="problem" style="background:#f8f8f8;" class="py-24 lg:py-32 overflow-hidden">
  <Wrapper variant="standard">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-10 lg:gap-12 items-start">

      <!-- Left 1/3: image -->
      <div class="lg:sticky lg:top-28">
        <div class="relative rounded-2xl overflow-hidden" style="aspect-ratio:3/4;">
          <img
            src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=760&h=1000&fit=crop&q=80"
            alt="Business owner checking Google reviews on phone"
            class="w-full h-full object-cover object-center"
            loading="lazy"
          />
          <div class="absolute bottom-5 left-5 right-5 rounded-xl px-4 py-3" style="background:rgba(26,58,42,0.92); backdrop-filter:blur(8px);">
            <Text tag="p" variant="textXS" class="font-bold" style="color:#f68c2b;">7 out of 10</Text>
            <Text tag="p" variant="textXS" style="color:#c2d9c9; line-height:1.4;">customers will review when asked the right way</Text>
          </div>
        </div>
      </div>

      <!-- Right 2/3: heading top + cards below -->
      <div class="flex flex-col gap-8">

        <!-- Top: kicker + heading + description -->
        <div class="flex flex-col gap-4">
          <Kicker variant="pill">Why reviews are hard to get</Kicker>
          <Text tag="h2" variant="displayMD" class="font-display font-bold text-base-950 tracking-tight leading-tight">
            You're doing great work.<br>Nobody's writing about it.
          </Text>
          <Text tag="p" variant="textSM" class="text-base-500 leading-relaxed max-w-lg">
            The frustrating truth is that happy customers and reviewers are rarely the same person. It's not that they don't care. It's that the moment passes.
          </Text>
        </div>

        <!-- Nav + counter -->
        <div class="flex items-center justify-between">
          <Text tag="span" variant="textXS" class="text-base-500 font-medium tabular-nums" id="prob-counter">1 / {problems.length}</Text>
          <div class="flex items-center gap-3">
            <button id="prob-prev" aria-label="Previous" class="size-10 rounded-full border border-base-300 bg-white flex items-center justify-center hover:border-base-500 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-base-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            <button id="prob-next" aria-label="Next" class="size-10 rounded-full border border-base-300 bg-white flex items-center justify-center hover:border-base-500 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-base-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Cards -->
        <div class="overflow-hidden">
          <div id="prob-track" class="flex gap-4 transition-transform duration-500 ease-in-out">
        {problems.map((p) => (
          <div class="prob-slide shrink-0 w-[85vw] sm:w-[380px] lg:w-[340px] xl:w-[380px]">
            <div
              class="rounded-2xl p-6 h-full flex flex-col relative"
              style="background:#fff; border:1px solid #efefef; box-shadow:0 2px 20px rgba(0,0,0,0.05);"
            >
              <!-- Label -->
              <Text tag="p" variant="textXS" class="uppercase tracking-widest font-medium text-base-400 mb-3">
                {p.label}
              </Text>

              <!-- Quote / problem body -->
              <Text tag="p" variant="textBase" class="text-base-800 leading-relaxed flex-1">
                {p.quote}
              </Text>

              <!-- Stat row -->
              <div class="flex items-center gap-2 mt-4">
                <span class="text-2xl font-bold font-display" style="color:#f68c2b;">{p.stat}</span>
                <Text tag="span" variant="textXS" class="text-base-400 leading-snug" style="max-width:160px;">
                  {p.statLabel}
                </Text>
              </div>

              <!-- Large decorative quote mark -->
              <div class="absolute bottom-16 right-5 select-none pointer-events-none text-base-100" style="font-size:3.5rem; line-height:1; font-family:Georgia,serif;">"</div>

              <!-- Icon badge -->
              <div class="flex items-center gap-3 mt-5 pt-4 border-t border-base-100">
                <div
                  class="size-10 rounded-full flex items-center justify-center text-xl shrink-0"
                  style={`background:${p.accent};`}
                >
                  {p.icon}
                </div>
                <Text tag="p" variant="textXS" class="text-base-500 leading-snug">
                  TapThrive solves this automatically
                </Text>
              </div>
            </div>
          </div>
        ))}
      </div>
        </div>

      </div><!-- /right col -->
    </div><!-- /grid -->

  </Wrapper>

  <!-- Stats row -->
  <div class="mt-20">
    <div class="text-center mb-12 px-4">
      <Text tag="h3" variant="displayMD" class="font-display font-bold text-base-950 tracking-tight">
        The numbers behind the problem.
      </Text>
    </div>

    <div
      id="prob-stats-scroll"
      class="flex items-stretch overflow-x-auto pb-4 cursor-grab active:cursor-grabbing select-none"
      style="-webkit-overflow-scrolling:touch; scrollbar-width:none;"
    >
      <div class="shrink-0 w-12 lg:w-24"></div>

      {stats.map((s, i) => (
        <div
          class="shrink-0 rounded-2xl p-8 flex flex-col justify-between border border-base-100 shadow-sm"
          style={`background:${i === 0 ? "#f68c2b" : "#fff"}; min-width:220px; margin-left:${i === 0 ? "0" : "16px"};`}
        >
          <Text
            tag="p"
            variant="display2XL"
            class="font-display font-bold leading-none"
            style={`color:${i === 0 ? "#fff" : "#f68c2b"};`}
          >
            {s.value}
          </Text>
          <Text
            tag="p"
            variant="textSM"
            class="mt-4 leading-snug"
            style={`color:${i === 0 ? "#fff" : "#7a7a72"};`}
          >
            {s.label}
          </Text>
        </div>
      ))}

      <!-- CTA card -->
      <div class="shrink-0 rounded-2xl p-8 flex flex-col justify-between ml-4" style="background:#f5f0e8; border:1px solid #ede8e0; min-width:220px;">
        <Text tag="p" variant="displayXS" class="font-display font-bold text-base-950 leading-tight">
          TapThrive fixes all four.
        </Text>
        <a
          href="https://wa.me/254718735565"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 rounded-full px-4 py-2.5 text-sm font-semibold text-white w-fit hover:opacity-80 transition-opacity"
          style="background:#f68c2b;"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          See how
        </a>
      </div>

      <!-- Drag hint -->
      <div class="shrink-0 ml-6 self-center">
        <Text tag="p" variant="textXS" class="text-base-400 uppercase tracking-widest">‹ Drag ›</Text>
      </div>

      <div class="shrink-0 w-12 lg:w-24"></div>
    </div>
  </div>

</section>

<style>
  #prob-stats-scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  // Problem carousel
  const track   = document.getElementById("prob-track") as HTMLElement;
  const counter = document.getElementById("prob-counter") as HTMLElement;
  const slides  = Array.from(track.querySelectorAll<HTMLElement>(".prob-slide"));
  const total   = slides.length;
  let current   = 0;

  function slideWidth() { return slides[0].offsetWidth + 16; }

  function goTo(idx: number) {
    current = (idx + total) % total;
    track.style.transform = `translateX(-${current * slideWidth()}px)`;
    counter.textContent   = `${current + 1} / ${total}`;
  }

  document.getElementById("prob-prev")?.addEventListener("click", () => goTo(current - 1));
  document.getElementById("prob-next")?.addEventListener("click", () => goTo(current + 1));

  // Drag stats scroll
  const statsScroll = document.getElementById("prob-stats-scroll") as HTMLElement;
  let isDown = false, startX = 0, scrollLeft = 0;
  statsScroll.addEventListener("mousedown",  (e) => { isDown = true; startX = e.pageX - statsScroll.offsetLeft; scrollLeft = statsScroll.scrollLeft; });
  statsScroll.addEventListener("mouseleave", ()  => { isDown = false; });
  statsScroll.addEventListener("mouseup",    ()  => { isDown = false; });
  statsScroll.addEventListener("mousemove",  (e) => {
    if (!isDown) return;
    e.preventDefault();
    statsScroll.scrollLeft = scrollLeft - (e.pageX - statsScroll.offsetLeft - startX) * 1.5;
  });
</script>
