---
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section style="background:#ffffff;" class="py-20 lg:py-28 border-b border-base-100">
  <Wrapper variant="standard">
    <p class="font-display font-bold leading-tight tracking-tight" style="font-size:clamp(1.6rem, 3.2vw, 2.8rem); color:#0a0a0a;">
      TapThrive turns every customer visit into a reputation-building moment.
      One tap or scan opens a smart landing page — it captures their WhatsApp number,
      reads how the experience went, sends happy customers to Google, and quietly routes
      complaints to you before they go public. Then it follows up automatically,{" "}
      <span style="color:#c8c8c4;">so nothing slips through.</span>
    </p>
  </Wrapper>
</section>
