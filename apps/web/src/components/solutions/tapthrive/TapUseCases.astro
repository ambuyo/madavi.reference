---
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const industries = [
  {
    name: "Restaurants & Cafés",
    tagline: "Turn every table into a review",
    body: "Customers tap after their meal — happy ones go straight to Google, unhappy ones send you a private message.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6">
      <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/>
      <path d="M7 2v20M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
    </svg>`,
  },
  {
    name: "Clinics & Pharmacies",
    tagline: "Build patient trust before they walk in",
    body: "Cards at reception capture sentiment the moment it's highest. Complaints handled privately — never publicly.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6">
      <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
    </svg>`,
  },
  {
    name: "Salons & Spas",
    tagline: "Your clients love you. Now let Google know.",
    body: "A tap or scan at checkout captures that feeling. WhatsApp follow-ups turn first-timers into regulars.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6">
      <circle cx="6" cy="6" r="3"/><circle cx="18" cy="18" r="3"/>
      <path d="M20 4L8.12 15.88M14.47 14.48L20 20M8.12 8.12L12 12"/>
    </svg>`,
  },
  {
    name: "Hotels & Hospitality",
    tagline: "Protect your rating across every touchpoint",
    body: "Catch guest complaints before they reach TripAdvisor or Google. AI responses keep your brand voice consistent.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6">
      <path d="M3 22V8l9-6 9 6v14"/><path d="M9 22V12h6v10"/><path d="M3 8h18"/>
    </svg>`,
  },
  {
    name: "Banks & SACCOs",
    tagline: "Show members their experience matters",
    body: "Branch-level sentiment tracking in real time. Member complaints resolved before they become public.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6">
      <path d="M3 22h18M6 18V11M10 18V11M14 18V11M18 18V11M12 2L2 7h20L12 2z"/>
    </svg>`,
  },
  {
    name: "Retail & Showrooms",
    tagline: "Every purchase is a potential five-star review",
    body: "Cards at checkout capture purchase satisfaction automatically. Monthly reports show what drives positive sentiment.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6">
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 01-8 0"/>
    </svg>`,
  },
];
---

<section id="use-cases" style="background:#f8f8f8;" class="py-24 lg:py-32">
  <Wrapper variant="standard">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: heading + 2-col industry grid -->
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-4">
          <Kicker variant="default">Who it's for</Kicker>
          <Text tag="h2" variant="displayMD" class="font-display font-bold text-base-950 tracking-tight leading-tight">
            If trust drives your business, TapThrive was built for you.
          </Text>
          <Text tag="p" variant="textBase" class="text-base-500 leading-relaxed max-w-lg">
            Any business where customers choose you based on what others say about you. That's most local businesses in Kenya.
          </Text>
        </div>

        <!-- 2-column industry grid -->
        <div class="grid grid-cols-2 gap-x-8 gap-y-8">
          {industries.map((item) => (
            <div class="flex flex-col gap-3">
              <!-- Icon -->
              <div
                class="size-12 rounded-xl flex items-center justify-center border border-base-200 text-base-700"
                style="background:#fff;"
              >
                <Fragment set:html={item.icon} />
              </div>
              <!-- Title + tagline -->
              <div class="flex flex-col gap-1">
                <Text tag="h3" variant="textBase" class="font-semibold text-base-950">
                  {item.name}
                </Text>
                <Text tag="p" variant="textSM" class="text-base-500 leading-relaxed">
                  {item.body}
                </Text>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <a
          href="https://wa.me/254718735565"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-semibold text-white w-fit hover:opacity-80 transition-opacity"
          style="background:#1a3a2a;"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Not sure if it fits? Chat with us
        </a>
      </div>

      <!-- Right: image with floating UI mockups -->
      <div class="relative">
        <!-- Main image -->
        <div class="relative rounded-2xl overflow-hidden" style="aspect-ratio:4/5;">
          <img
            src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&h=1000&fit=crop&q=80"
            alt="Business owner reviewing TapThrive dashboard"
            class="w-full h-full object-cover object-center"
            loading="lazy"
            style="filter: grayscale(15%);"
          />
          <!-- Dark overlay at bottom -->
          <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(26,58,42,0.3) 0%, transparent 50%);"></div>
        </div>

        <!-- Floating: review prompt card (top right) -->
        <div class="absolute -top-4 -right-4 rounded-2xl shadow-xl p-4 w-56 border border-base-100" style="background:#fff;">
          <div class="flex items-center gap-2 mb-2">
            <div class="size-5 rounded-full flex items-center justify-center text-white text-[9px] font-bold" style="background:#1a3a2a;">T</div>
            <Text tag="p" variant="textXS" class="font-semibold text-base-700">tapthrive.app</Text>
            <span class="ml-auto text-[10px] font-medium px-1.5 py-0.5 rounded-full" style="background:#e8f0eb; color:#1a3a2a;">Live</span>
          </div>
          <Text tag="p" variant="textXS" class="font-semibold text-base-900 mb-1">How was your visit?</Text>
          <Text tag="p" variant="textXS" class="text-base-400 mb-2">Java House, Westlands</Text>
          <div class="flex gap-0.5 mb-2">
            {Array.from({length:5}).map(() => (
              <svg class="size-3.5" viewBox="0 0 20 20" fill="#F5A623">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <div class="w-full rounded-full text-center text-[11px] font-medium text-white py-1.5" style="background:#1a3a2a;">
            Leave a Google review →
          </div>
        </div>

        <!-- Floating: WhatsApp follow-up (bottom left) -->
        <div class="absolute -bottom-4 -left-4 rounded-2xl shadow-xl p-4 w-60 border border-base-100" style="background:#fff;">
          <div class="flex items-center gap-2 mb-3">
            <div class="size-7 rounded-full flex items-center justify-center shrink-0" style="background:#25D366;">
              <svg class="size-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a9.47 9.47 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
              </svg>
            </div>
            <div>
              <Text tag="p" variant="textXS" class="font-semibold text-base-900">WhatsApp follow-up sent</Text>
              <Text tag="p" variant="textXS" class="text-base-400">2 hrs after tap · automated</Text>
            </div>
          </div>
          <div class="rounded-xl px-3 py-2.5 text-xs" style="background:#f0f7f2; color:#1a3a2a; line-height:1.5;">
            "Hi! Thanks for visiting Java House. Did you get a chance to leave us a Google review? It only takes 30 seconds 🙏"
          </div>
        </div>

        <!-- Floating: rating badge (middle right) -->
        <div class="absolute top-1/2 -translate-y-1/2 -right-6 rounded-2xl shadow-xl px-4 py-3 border border-base-100 flex items-center gap-3" style="background:#fff;">
          <div class="flex flex-col items-center">
            <Text tag="p" variant="displayXS" class="font-display font-bold" style="color:#1a3a2a;">4.8</Text>
            <div class="flex gap-0.5">
              {Array.from({length:5}).map(() => (
                <svg class="size-2.5" viewBox="0 0 20 20" fill="#F5A623">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
          </div>
          <div>
            <Text tag="p" variant="textXS" class="font-semibold text-base-900">Google Rating</Text>
            <Text tag="p" variant="textXS" class="text-green-600">↑ +0.3 this month</Text>
          </div>
        </div>

      </div>
    </div>
  </Wrapper>
</section>
