---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { TapThrivePricingReact } from "@/components/solutions/tapthrive/TapThrivePricingReact";
---

<section id="pricing" class="relative overflow-hidden py-24 lg:py-32">

  <!-- Grainy dark background -->
  <div class="absolute inset-0 z-0" style="background-color: #0a0a0a;">
    <svg class="absolute inset-0 w-full h-full opacity-40" xmlns="http://www.w3.org/2000/svg">
      <filter id="tt-pricing-noise">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
        <feColorMatrix type="saturate" values="0"/>
      </filter>
      <rect width="100%" height="100%" filter="url(#tt-pricing-noise)" opacity="1"/>
    </svg>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 15% 60%, rgba(180,50,20,0.55) 0%, transparent 65%), radial-gradient(ellipse 50% 40% at 85% 40%, rgba(100,80,30,0.35) 0%, transparent 60%);"></div>
  </div>

  <Wrapper variant="standard" class="relative z-10">

    <!-- React creative pricing component -->
    <TapThrivePricingReact client:visible />

    <!-- Setup fee note -->
    <div class="mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-3 rounded-xl border border-white/10 px-6 py-4">
      <svg class="size-5 text-amber-400 shrink-0" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
      </svg>
      <Text tag="p" variant="textXS" class="text-white/50">
        <span class="text-white/80 font-medium">KSh 5,000 setup fee (once)</span> — includes branded NFC card(s), landing page, and Google Business profile setup. Multiple locations? Rates drop automatically.
        <a href="https://wa.me/254718735565" target="_blank" rel="noopener noreferrer" class="underline text-white/70 hover:text-white ml-1">
          Not sure which plan? Chat with us →
        </a>
      </Text>
    </div>

  </Wrapper>
</section>
