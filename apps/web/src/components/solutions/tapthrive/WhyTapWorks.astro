---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const pillars = [
  {
    label: "Local market expertise",
    title: "We know Kenyan customers.",
    body: "WhatsApp-first communication, local business dynamics, how trust is built face-to-face — every feature was designed for this market, not adapted from one that doesn't fit.",
  },
  {
    label: "System thinking",
    title: "We think beyond the tap.",
    body: "The card — tap or scan — is the entry point. The system — the filter, the follow-up, the database, the report — is what compounds over time. We're here for what happens after month one.",
  },
  {
    label: "Long-term partnership",
    title: "We grow with you.",
    body: "Start with one location. Scale to fifteen. Add your contact list to a WhatsApp broadcast campaign. Use your reputation data to make staffing and product decisions. TapThrive grows into whatever your business needs.",
  },
];
---

<section style="background:#f5f0e8;" class="py-24 lg:py-32">
  <Wrapper variant="standard">
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-12 lg:gap-20 items-start">

      <!-- Left: heading + statement + CTA -->
      <div class="lg:sticky lg:top-28 flex flex-col gap-8">

        <div class="flex flex-col gap-5">
          <Text tag="p" variant="textXS" class="uppercase tracking-widest font-medium text-base-500">
            Why it works
          </Text>

          <h2 class="font-display font-bold leading-tight tracking-tight" style="font-size:clamp(2rem,4vw,3.2rem); color:#1a3a2a;">
            Built on <em style="font-style:italic; font-family:'DM Serif Display',serif;">real marketing<br>experience.</em> Not just tech.
          </h2>

          <Text tag="p" variant="textBase" class="leading-relaxed" style="color:#4a4a45;">
            TapThrive turns every customer visit into a reputation-building moment.
            One tap or scan opens a smart landing page — it captures their WhatsApp number,
            reads how the experience went, sends happy customers to Google, and quietly routes
            complaints to you before they go public. Then it follows up automatically,
            so nothing slips through.
          </Text>
        </div>

        <a
          href="https://wa.me/254718735565"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-full px-6 py-3 text-sm font-semibold text-white w-fit transition-opacity hover:opacity-80"
          style="background:#1a3a2a;"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chat with us
        </a>

      </div>

      <!-- Right: pillar list -->
      <div class="flex flex-col divide-y" style="border-color:#ddd9d0;">
        {pillars.map((p) => (
          <div class="flex items-start gap-5 py-10 first:pt-0 last:pb-0">
            <!-- Bullet -->
            <span class="size-2 rounded-full shrink-0 mt-3" style="background:#1a3a2a;"></span>

            <!-- Content -->
            <div class="flex flex-col gap-3">
              <Text tag="p" variant="textXS" class="uppercase tracking-widest font-medium text-base-400">
                {p.label}
              </Text>

              <h3 class="font-display font-bold leading-snug" style="font-size:clamp(1.4rem,2.2vw,1.9rem); color:#1a3a2a;">
                {p.title}
              </h3>

              <Text tag="p" variant="textBase" class="leading-relaxed" style="color:#4a4a45;">
                {p.body}
              </Text>
            </div>
          </div>
        ))}
      </div>

    </div>
  </Wrapper>
</section>
