---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const included = [
  "Claim or create your Google Business listing",
  "Business name, category, address, hours, phone, website & WhatsApp link",
  "Upload 10–15 photos (interior, exterior, product/service)",
  "Keyword-rich business description written for local search",
  "Primary + secondary categories selected correctly",
  "Products / services with descriptions and prices",
  "Business attributes (parking, payment methods, accessibility etc.)",
  "Q&A section populated with common customer questions",
  "Google Messaging activated",
  "Initial post published to activate the profile",
  "Verification followed through — including handling Google's back-and-forth",
];

const pricing = [
  {
    label: "Already a TapThrive client",
    price: "Included",
    note: "Bundled in your KSh 5,000 setup fee. No extra charge.",
    highlight: true,
  },
  {
    label: "Existing client — GMB needs fixing",
    price: "KSh 4,500",
    note: "You're already on TapThrive but your profile needs proper optimisation.",
    highlight: false,
  },
  {
    label: "No GMB — full setup before onboarding",
    price: "KSh 5,000",
    note: "Separate from the TapThrive setup fee. Takes 3–7 days including verification.",
    highlight: false,
  },
  {
    label: "Multi-location (per branch)",
    price: "KSh 3,000",
    note: "Per location after the first, for clients setting up 3+ branches.",
    highlight: false,
  },
];
---

<section id="gmb-setup" style="background:#faf8f5;" class="py-24 lg:py-32">
  <Wrapper variant="standard">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left: what's included -->
      <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-4">
          <Text tag="p" variant="textXS" class="uppercase tracking-widest font-semibold" style="color:#f68c2b; letter-spacing:.14em;">
            Google Business Profile setup
          </Text>
          <Text tag="h2" variant="displayMD" class="font-display font-bold text-base-950 tracking-tight leading-tight">
            No Google Business Profile? We'll build it — and build it properly.
          </Text>
          <Text tag="p" variant="textBase" class="text-base-500 leading-relaxed">
            TapThrive works best when your Google Business Profile is verified, optimised, and active.
            Most "setup" services fill in the basics and walk away. We don't — because wrong category
            selection, skipped attributes, and unverified listings quietly kill your local search ranking.
          </Text>
        </div>

        <!-- What's included list -->
        <div class="rounded-2xl border border-base-200 overflow-hidden" style="background:#fff;">
          <div class="px-6 py-4 border-b border-base-100" style="background:#f68c2b;">
            <Text tag="p" variant="textSM" class="font-semibold" style="color:#fff;">
              What our full setup includes
            </Text>
          </div>
          <ul class="divide-y divide-base-100">
            {included.map((item) => (
              <li class="flex items-start gap-3 px-6 py-3">
                <svg class="size-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8.5l3.5 3.5 6.5-7" stroke="#f68c2b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <Text tag="span" variant="textSM" class="text-base-700">{item}</Text>
              </li>
            ))}
          </ul>
        </div>

        <!-- Honest note -->
        <div class="rounded-xl px-5 py-4 border border-amber-200" style="background:#fdf6ee;">
          <Text tag="p" variant="textXS" class="text-base-600 leading-relaxed">
            <span class="font-semibold text-base-800">The honest reality:</span> GMB setup alone is a commodity — there are sellers doing it for KSh 500. What you're paying for is correct category selection (wrong choice kills local SEO), verification follow-through (Google's process is genuinely painful), and the depth of optimisation that most "setup" services skip entirely.
          </Text>
        </div>
      </div>

      <!-- Right: pricing -->
      <div class="flex flex-col gap-4 lg:sticky lg:top-28">

        <Text tag="h3" variant="displayXS" class="font-display font-bold text-base-950 leading-tight">
          What it costs
        </Text>
        <Text tag="p" variant="textSM" class="text-base-500 mb-2">
          Most TapThrive clients already have this covered in their setup fee. Here's how it works for every scenario.
        </Text>

        <div class="flex flex-col gap-3">
          {pricing.map((tier) => (
            <div
              class={`rounded-xl p-5 border flex flex-col gap-2 ${tier.highlight ? "border-green-200" : "border-base-200"}`}
              style={tier.highlight ? "background:#f0f7f2;" : "background:#fff;"}
            >
              <div class="flex items-start justify-between gap-3">
                <Text tag="p" variant="textSM" class="font-semibold text-base-900 leading-snug">
                  {tier.label}
                </Text>
                <span
                  class={`text-sm font-bold shrink-0 ${tier.highlight ? "text-green-700" : "text-base-950"}`}
                  style={!tier.highlight ? "color:#f68c2b;" : ""}
                >
                  {tier.price}
                </span>
              </div>
              <Text tag="p" variant="textXS" class="text-base-500 leading-relaxed">
                {tier.note}
              </Text>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-2 flex flex-col gap-3">
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-80"
            style="background:#f68c2b;"
          >
            Get your GMB set up — chat with us
          </a>
          <a href="#contact" class="text-xs text-base-400 text-center hover:text-base-700 transition-colors">
            Not sure if yours needs work? Send us your Google Business link and we'll tell you for free.
          </a>
        </div>

      </div>
    </div>

  </Wrapper>
</section>
