---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const rows = [
  { locations: "1 location",     setup: "KSh 5,000", tap: "KSh 2,500", grow: "KSh 5,000", glow: "KSh 9,000", featured: false },
  { locations: "2–5 locations",  setup: "KSh 3,500", tap: "KSh 2,000", grow: "KSh 4,000", glow: "KSh 7,500", featured: false },
  { locations: "6–15 locations", setup: "KSh 2,500", tap: "KSh 1,500", grow: "KSh 3,000", glow: "KSh 5,500", featured: true  },
  { locations: "15+ locations",  setup: "Custom",    tap: "Custom",    grow: "Custom",    glow: "Custom",    featured: false },
];

const cols = ["Locations", "Setup / location", "Tap / mo", "Tap + Grow / mo", "Tap + Glow / mo"];
---

<section id="multi-location" class="py-24 lg:py-32" style="background:#faf8f5;">
  <Wrapper variant="standard">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-2 border border-base-200 rounded-full px-4 py-1.5 w-fit">
          <span class="text-base-400 text-xs">✦</span>
          <Text tag="span" variant="textXS" class="text-base-500 font-medium tracking-wide">
            Multiple locations
          </Text>
          <span class="text-base-400 text-xs">✦</span>
        </div>
        <Text tag="h2" variant="displayMD" class="font-display font-bold text-base-950 tracking-tight leading-tight">
          The more branches you manage,<br>the less you pay per branch.
        </Text>
        <Text tag="p" variant="textSM" class="text-base-500 max-w-md leading-relaxed">
          Multi-location businesses get automatic volume discounts — no negotiation, no custom quotes for standard tiers. The pricing table tells you exactly what you'll pay before you ever contact us.
        </Text>
      </div>

      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white shrink-0 hover:opacity-80 transition-opacity"
        style="background:#f68c2b;"
      >
        15+ locations? Let's talk enterprise →
      </a>
    </div>

    <!-- Table -->
    <div class="rounded-2xl overflow-hidden border border-base-200">
      <table class="w-full border-collapse">
        <!-- Head -->
        <thead>
          <tr style="background:#f68c2b;">
            {cols.map((col, i) => (
              <th class={`px-5 py-4 text-left text-xs font-medium tracking-widest uppercase ${i === 0 ? "text-white" : "text-white"}`} style="color: #fff; letter-spacing:.08em;">
                {col}
              </th>
            ))}
          </tr>
        </thead>

        <!-- Body -->
        <tbody>
          {rows.map((row) => (
            <tr
              class="border-b border-base-100 transition-colors duration-150 hover:bg-base-50 group"
              style={row.featured ? "background:#f0f7f2;" : "background:#ffffff;"}
            >
              <!-- Locations -->
              <td class="px-5 py-4">
                <div class="flex items-center gap-2">
                  <Text tag="span" variant="textSM" class="font-semibold text-base-900">
                    {row.locations}
                  </Text>
                  {row.featured && (
                    <span class="text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full text-white" style="background:#f68c2b; letter-spacing:.06em;">
                      Best value
                    </span>
                  )}
                  {row.locations === "15+ locations" && (
                    <span class="text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:#f5e6cc; color:#f68c2b; letter-spacing:.06em;">
                      Enterprise
                    </span>
                  )}
                </div>
              </td>

              <!-- Setup -->
              <td class="px-5 py-4">
                <Text tag="span" variant="textSM" class={row.setup === "Custom" ? "text-base-400 italic" : "text-base-700"}>
                  {row.setup}
                </Text>
              </td>

              <!-- Tap -->
              <td class="px-5 py-4">
                <Text tag="span" variant="textSM" class={row.tap === "Custom" ? "text-base-400 italic" : "text-base-700"}>
                  {row.tap}
                </Text>
              </td>

              <!-- Tap + Grow -->
              <td class="px-5 py-4">
                <Text tag="span" variant="textSM" class={row.grow === "Custom" ? "text-base-400 italic" : "font-medium text-base-900"}>
                  {row.grow}
                </Text>
              </td>

              <!-- Tap + Glow -->
              <td class="px-5 py-4">
                <Text tag="span" variant="textSM" class={row.glow === "Custom" ? "text-base-400 italic" : "text-base-700"}>
                  {row.glow}
                </Text>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Footnote -->
    <!-- Real example -->
    <div class="mt-4 rounded-xl px-5 py-4 border border-base-200" style="background:#f0f7f2;">
      <Text tag="p" variant="textXS" class="text-base-700 leading-relaxed">
        <span class="font-semibold text-base-900">Real example:</span> A restaurant chain with 8 branches on Tap + Grow pays KSh 20,000 setup (once) and KSh 24,000/month. That's KSh 288,000/year for a fully managed reputation system across all 8 locations — less than one full-page newspaper ad.
      </Text>
    </div>

    <!-- Footnote -->
    <div class="mt-4 flex items-start gap-3 rounded-xl px-5 py-4 border border-amber-200" style="background:#fdf6ee;">
      <svg class="size-5 text-amber-500 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
      </svg>
      <Text tag="p" variant="textXS" class="text-base-600 leading-relaxed">
        <span class="font-semibold text-base-800">Save 10% when you pay annually.</span>
        Enterprise plans (15+ locations) include a dedicated account manager, centralised dashboard, and priority support.
        <a href="https://wa.me/254718735565" target="_blank" rel="noopener noreferrer" class="underline text-base-700 hover:text-base-950 ml-1">Get a custom quote →</a>
      </Text>
    </div>

  </Wrapper>
</section>
