---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Fundations
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Search from "@/components/global/Search.astro";
import MobileNav from "@/components/global/MobileNav.astro";
import Megamenu from "@/components/global/Megamenu.astro";
import ResourcesMegamenu from "@/components/global/ResourcesMegamenu.astro";

// Navigation links
const navLinks = [
  { label: "Capabilities", href: "/capabilities", hasMegamenu: true },
  { label: "Resources", href: "/resources", hasMegamenu: true },
  { label: "Our Work", href: "/our-work" },
  { label: "About", href: "/about" },
  { label: "Our Approach", href: "/our-approach" },
  { label: "Contact", href: "/get-a-proposal" },
];

const headerBaseClass = "fixed inset-x-0 top-0 z-50 transition-all duration-300";
---

<header class={`${headerBaseClass} bg-[#005B65]`} data-navbar-variant="industry">
  <Wrapper variant="standard" class="py-6">
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 max-w-xs transition-colors text-white [.scrolled_&]:text-base-900">
        <div class="logo-container">
          <Logo variant="light" class="h-16 w-auto light-logo" />
          <Logo variant="dark" class="h-16 w-auto dark-logo hidden" />
        </div>
      </a>
      <nav class="hidden items-center lg:flex group peer" aria-label="Primary">
        <div class="flex items-center gap-8 px-8 py-4 rounded-full bg-white/10 backdrop-blur-md border border-white/20 group-hover:bg-white/20">
          {
            navLinks.map((link) => {
              const hasMegamenu = link.hasMegamenu;
              return (
                <a
                  href={link.href}
                  data-megamenu={link.label.toLowerCase()}
                  class={`text-sm font-medium transition-colors text-white/80 hover:text-white [.scrolled_&]:text-base-700 [.scrolled_&]:hover:text-base-950 ${hasMegamenu ? "has-megamenu" : ""}`}
                >
                  {link.label}
                </a>
              );
            })
          }
        </div>
      </nav>
      <div class="flex items-center gap-2">
        <Search variant="transparent" />
        <Button
          isLink
          size="xs"
          variant="light"
          href="/get-a-proposal"
          class="hidden lg:flex px-6 py-2 rounded-full bg-white text-base-900 font-medium hover:bg-gray-100 [.scrolled_&]:bg-base-900 [.scrolled_&]:text-white [.scrolled_&]:hover:bg-base-800"
        >
          Get My AI Audit
        </Button>
        <MobileNav links={navLinks} variant="transparent" />
      </div>
    </div>
  </Wrapper>
  <div class="group/megamenu">
    <Megamenu />
  </div>
  <ResourcesMegamenu />
</header>

<script is:inline>
  // Handle navbar scroll detection
  function handleIndustryNavbarScroll() {
    const header = document.querySelector("header[data-navbar-variant='industry']");
    if (!header) return;

    const lightLogo = header.querySelector(".light-logo");
    const darkLogo = header.querySelector(".dark-logo");

    function updateNavbarStyle() {
      const isScrolled = window.scrollY > 10;
      if (isScrolled) {
        header.classList.add("scrolled");
        header.classList.add("bg-white");
        header.classList.add("border-b");
        header.classList.add("border-base-200");
        header.classList.add("shadow-sm");
        header.classList.remove("bg-[#005B65]");

        // Switch to dark logo when scrolled
        if (lightLogo) lightLogo.classList.add("hidden");
        if (darkLogo) darkLogo.classList.remove("hidden");
      } else {
        header.classList.remove("scrolled");
        header.classList.remove("bg-white");
        header.classList.remove("border-b");
        header.classList.remove("border-base-200");
        header.classList.remove("shadow-sm");
        header.classList.add("bg-[#005B65]");

        // Switch to light logo when at top
        if (lightLogo) lightLogo.classList.remove("hidden");
        if (darkLogo) darkLogo.classList.add("hidden");
      }
    }

    updateNavbarStyle();
    window.addEventListener("scroll", updateNavbarStyle);
  }

  handleIndustryNavbarScroll();

  // Megamenu interactions
  document.addEventListener("DOMContentLoaded", function() {
    const header = document.querySelector("header[data-navbar-variant='industry']");
    if (!header) return;

    const capabilitiesLink = header.querySelector('[data-megamenu="capabilities"]');
    const resourcesLink = header.querySelector('[data-megamenu="resources"]');
    const megamenu = header.querySelector("#megamenu");
    const resourcesMegamenu = header.querySelector("#resources-megamenu");

    const hideAllMenus = () => {
      megamenu?.classList.add("hidden");
      resourcesMegamenu?.classList.add("hidden");
    };

    const showCapabilitiesMenu = () => {
      hideAllMenus();
      megamenu?.classList.remove("hidden");
    };

    const showResourcesMenu = () => {
      hideAllMenus();
      resourcesMegamenu?.classList.remove("hidden");
    };

    if (capabilitiesLink) {
      capabilitiesLink.addEventListener("mouseenter", showCapabilitiesMenu);
      capabilitiesLink.addEventListener("mouseleave", () => {
        setTimeout(() => { if (!megamenu?.matches(":hover")) hideAllMenus(); }, 100);
      });
    }

    if (resourcesLink) {
      resourcesLink.addEventListener("mouseenter", showResourcesMenu);
      resourcesLink.addEventListener("mouseleave", () => {
        setTimeout(() => { if (!resourcesMegamenu?.matches(":hover")) hideAllMenus(); }, 100);
      });
    }

    if (megamenu) {
      megamenu.addEventListener("mouseenter", showCapabilitiesMenu);
      megamenu.addEventListener("mouseleave", hideAllMenus);
    }

    if (resourcesMegamenu) {
      resourcesMegamenu.addEventListener("mouseenter", showResourcesMenu);
      resourcesMegamenu.addEventListener("mouseleave", hideAllMenus);
    }
  });
</script>
