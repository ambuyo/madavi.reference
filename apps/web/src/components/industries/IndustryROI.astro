---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Stat {
  label: string;
  value: string;
}

interface BeforeAfter {
  title: string;
  stats: Stat[];
}

interface SecondaryBenefit {
  title: string;
  description: string;
}

interface Props {
  title: string;
  before: BeforeAfter;
  after: BeforeAfter;
  investment: string;
  netBenefit: string;
  roiPercentage: string;
  secondaryBenefits: SecondaryBenefit[];
}

const {
  title,
  before,
  after,
  investment,
  netBenefit,
  roiPercentage,
  secondaryBenefits,
} = Astro.props;
---

<section class="bg-base-50 py-16 lg:py-24">
  <Wrapper variant="standard">
    <Text
      tag="h2"
      variant="displayLG"
      class="text-base-900 text-balance font-display mb-16"
    >
      {title}
    </Text>

    <div class="grid md:grid-cols-2 gap-12 mb-16">
      <!-- Before Column -->
      <div>
        <Text
          tag="h3"
          variant="textXL"
          class="text-base-900 font-semibold mb-8"
        >
          {before.title}
        </Text>
        <div class="space-y-6">
          {
            before.stats.map((stat) => (
              <div class="border-l-4 border-base-300 pl-4">
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-base-600 mb-1"
                >
                  {stat.label}
                </Text>
                <Text
                  tag="p"
                  variant="displaySM"
                  class="text-base-900 font-bold"
                >
                  {stat.value}
                </Text>
              </div>
            ))
          }
        </div>
      </div>

      <!-- After Column -->
      <div>
        <Text
          tag="h3"
          variant="textXL"
          class="text-base-900 font-semibold mb-8"
        >
          {after.title}
        </Text>
        <div class="space-y-6">
          {
            after.stats.map((stat) => (
              <div class="border-l-4 pl-4" style="border-left-color: #FF5F1F;">
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-base-600 mb-1"
                >
                  {stat.label}
                </Text>
                <Text
                  tag="p"
                  variant="displaySM"
                  class="font-bold"
                  style="color: #FF5F1F;"
                >
                  {stat.value}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ROI Highlight -->
    <div class="bg-white rounded-lg p-12 mb-16 border-2" style="border-color: #FF5F1F;">
      <Text
        tag="h3"
        variant="textBase"
        class="text-base-700 mb-4"
      >
        {investment}
      </Text>
      <div class="mb-4">
        <Text
          tag="p"
          variant="displayXL"
          class="font-bold"
          style="color: #FF5F1F;"
        >
          {netBenefit}
        </Text>
      </div>
      <Text
        tag="p"
        variant="textLG"
        class="text-base-900 font-semibold"
      >
        Net Year 1 Benefit | {roiPercentage} ROI
      </Text>
    </div>

    <!-- Secondary Benefits -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        secondaryBenefits.map((benefit) => (
          <div class="p-6 rounded-lg" style="background-color: #FF5F1F;">
            <Text
              tag="h4"
              variant="textBase"
              class="font-semibold mb-2"
              style="color: white;"
            >
              {benefit.title}
            </Text>
            <Text
              tag="p"
              variant="textSM"
              style="color: white;"
            >
              {benefit.description}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
