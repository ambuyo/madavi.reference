---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Tier {
  title: string;
  benefit: string;
  description: string;
  backgroundColor: string;
}

interface Props {
  title: string;
  description: string;
  tiers: Tier[];
}

const { title, description, tiers } = Astro.props;
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
        {title}
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-base-700 mt-4"
      >
        {description}
      </Text>
    </div>

    <div class="flex flex-col lg:flex-row gap-0 lg:gap-8 rounded-lg overflow-visible">
      {
        tiers.map((tier) => (
          <div class="flex-1 p-8 lg:p-12 flex flex-col justify-between text-white rounded-lg transition-all duration-300 hover:shadow-2xl hover:scale-105 hover:-rotate-1" style={`background-color: ${tier.backgroundColor}`}>
            <div class="text-left">
              {tier.benefit && (
                <div class="mb-4 inline-block bg-white/20 px-3 py-1 rounded-full">
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white font-semibold uppercase tracking-wide"
                  >
                    ✓ BENEFIT: {tier.benefit}
                  </Text>
                </div>
              )}
              <Text
                tag="h3"
                variant="textXL"
                class="text-white font-semibold mb-2"
              >
                {tier.title}
              </Text>
              <Text
                tag="p"
                variant="textSM"
                class="text-white/90"
              >
                {tier.description}
              </Text>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
