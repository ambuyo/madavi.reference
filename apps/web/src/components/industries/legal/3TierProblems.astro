---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const tiers = [
  {
    title: "Billable Hour Leakage",
    subtitle: "",
    benefit: "Revenue Impact",
    sections: {
      whatItIs: "Associates spend 30-40% of their time on tasks that should take minutes but consume hours. Every hour spent on document review that could be automated is revenue lost.",
      howWeDeliver: [
        "AI-powered document review cuts review time by 70%",
        "Automated legal research and case law analysis",
        "Intelligent contract analysis and risk flagging"
      ],
      whoThisServes: "Managing partners, operations leaders, and associate teams drowning in repetitive work that doesn't generate revenue."
    },
    bgColor: "#FFA500",
  },
  {
    title: "Client Response Speed",
    subtitle: "",
    benefit: "Competitive Advantage",
    sections: {
      whatItIs: "Corporate clients expect law firms to match the responsiveness they get from other professional services. When your competitor answers in hours and you take days, you lose matters.",
      howWeDeliver: [
        "24-hour turnarounds on contract review and preliminary analysis",
        "Automated client intake and status reporting",
        "AI-assisted deal structuring and risk assessment"
      ],
      whoThisServes: "Partners managing client relationships, practice groups competing for market share, and clients demanding faster counsel."
    },
    bgColor: "#EC5800",
  },
  {
    title: "Junior Associate Training Costs",
    subtitle: "",
    benefit: "Cost Reduction",
    sections: {
      whatItIs: "New associates take 18+ months to become profitable. AI can accelerate this by handling routine tasks and surfacing relevant precedents.",
      howWeDeliver: [
        "AI-powered knowledge base that surfaces relevant precedents and strategies",
        "Automated synthesis of client history and risk profiles",
        "Smart templates that adapt to practice area and client type"
      ],
      whoThisServes: "Practice group leaders, managing partners, and junior attorneys who waste weeks rediscovering what the firm already knows."
    },
    bgColor: "#FF5F1F",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
The Three Problems Worth Solving
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-base-700 mt-4"
      >
Most legal tech vendors sell platforms. Law firms need AI that fits existing workflows, ethics requirements, and client confidentiality standards.

      </Text>
    </div>

    <div class="flex flex-col lg:flex-row gap-0 lg:gap-8 rounded-lg overflow-visible">
      {
        tiers.map((tier) => (
          <div class={`flex-1 p-8 lg:p-12 flex flex-col justify-between text-white rounded-lg transition-all duration-300 hover:shadow-2xl hover:scale-105 hover:-rotate-1 ${tier.bgColor.startsWith('#') ? '' : tier.bgColor}`} style={tier.bgColor.startsWith('#') ? `background-color: ${tier.bgColor}` : ''}>
            <div class="text-left">
              {tier.benefit && (
                <div class="mb-4 inline-block bg-white/20 px-3 py-1 rounded-full">
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white font-semibold uppercase tracking-wide"
                  >
                    ✓ BENEFIT: {tier.benefit}
                  </Text>
                </div>
              )}
              <Text
                tag="h3"
                variant="textXL"
                class="text-white font-semibold mb-2"
              >
                {tier.title}
              </Text>
              {tier.subtitle && (
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-white/80 mb-6 italic"
                >
                  {tier.subtitle}
                </Text>
              )}

              <div class="space-y-4">
                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    The Problem
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class="text-white/90"
                  >
                    {tier.sections.whatItIs}
                  </Text>
                </div>

                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    Our Solution
                  </Text>
                  <ul class="space-y-1">
                    {tier.sections.howWeDeliver.map((item) => (
                      <li class="text-sm text-white/90">• {item}</li>
                    ))}
                  </ul>
                </div>

                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    For Whom
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class="text-white/90"
                  >
                    {tier.sections.whoThisServes}
                  </Text>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
