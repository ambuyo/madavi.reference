---
// Assets
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import talk from "@/images/assets/talk.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Props {
  title: string;
  description: string;
  narrativeParagraphs: string[];
  heroImage?: string | ImageMetadata;
}

const { title, description, narrativeParagraphs, heroImage } = Astro.props;
---

<section class="relative overflow-hidden">
  <img 
    src="/Solutions%20BG.png"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />
  <Wrapper variant="standard" class="relative z-10 py-12">
    <div
      class="grid md:grid-cols-2 lg:grid-cols-2 gap-0 bg-base-50 items-stretch"
    >
      <div class="overflow-hidden">
        {typeof heroImage === "string" ? (
          <img
            src={heroImage}
            alt="Value Proposition"
            loading="eager"
            decoding="async"
            class="w-full h-full object-cover object-center"
          />
        ) : (
          <Image
            src={heroImage || talk}
            alt="Value Proposition"
            width={800}
            height={800}
            loading="eager"
            decoding="async"
            class="w-full h-full object-cover object-center"
          />
        )}
      </div>
      <div class="flex flex-col p-8 lg:p-12">
        <div>
          <Text
            tag="h2"
            variant="displayMD"
            class="text-base-950 text-balance font-medium tracking-tight font-display"
          >
            {title}
          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="text-base-700 mt-6 text-pretty"
          >
            {description}
          </Text>
          {
            narrativeParagraphs.map((paragraph, index) => (
              <Text
                tag="p"
                variant="textBase"
                class={`text-base-700 ${index === narrativeParagraphs.length - 1 ? 'font-semibold' : ''} text-pretty`}
                style={`margin-top: ${index === 0 ? '24px' : '16px'}`}
              >
                {paragraph}
              </Text>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
