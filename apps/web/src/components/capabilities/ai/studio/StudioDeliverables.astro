---
// Assets
import { Image } from "astro:assets";
import talk from "@/images/assets/talk.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const features = [
  {
    title: "Technical Deliverables",
    items: [
      "Production-ready code and systems (not prototypes)",
      "Integration with your existing tech stack",
      "Security and compliance documentation",
      "Maintenance and troubleshooting runbooks",
    ],
  },
  {
    title: "Operational Enablement",
    items: [
      "Trained internal team who can operate and modify systems",
      "Performance monitoring dashboards",
      "Escalation protocols and support procedures",
      "Continuous improvement frameworks",
    ],
  },
  {
    title: "Business Outcomes",
    items: [
      "Measurable time savings (we track hours recovered)",
      "Error reduction in automated processes",
      "Cost analysis showing ROI trajectory",
      "Roadmap for scaling successful implementations",
    ],
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 lg:p-12 bg-base-50"
    >
      <div class="flex flex-col">
        <div>
          <Text
            tag="h2"
            variant="displayMD"
            class="text-base-950 text-balance font-medium tracking-tight font-display mt-8"
          >
            What you get
          </Text>
     
        </div>
        <div class="grid grid-cols-1 gap-y-12 mt-12">
          {
            features.map((feature) => (
              <div>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="text-base-900 font-display"
                >
                  {feature.title}
                </Text>
                <ul class="mt-3 space-y-2">
                  {feature.items.map((item) => (
                    <li class="flex gap-2">
                      <span class="text-base-600 flex-shrink-0">•</span>
                      <Text
                        tag="p"
                        variant="textSM"
                        class="text-base-600 text-pretty"
                      >
                        {item}
                      </Text>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
      <Image
        src={talk}
        alt="Image"
        width={800}
        height={1440}
        loading="eager"
        decoding="async"
        class="size-full object-cover object-center aspect-square"
      />
    </div>
  </Wrapper>
</section>
