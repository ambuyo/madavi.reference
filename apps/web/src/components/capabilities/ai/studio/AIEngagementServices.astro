---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";

const pillars = [
  {
    price: "$2.5k",
    duration: "4 weeks",
    title: "AI Readiness to Roadmap",
    subtitle: "Know exactly where to start — and what to do first.",
    sections: {
      whatItIs: "You leave with a clear, prioritised 6-month AI roadmap built around your actual operations — not a generic template. We assess where you stand, identify your highest-value opportunities, and hand you a plan your team can execute.",
      howWeDeliver: [
        "AI readiness assessment across strategy, data, and infrastructure",
        "Personalised 6-month roadmap with sequenced priorities",
        "Vendor recommendations tailored to your budget and stack",
        "2 implementation workshops with your leadership team",
        "Deliverable: PDF roadmap + Miro board"
      ],
      whoThisServes: "Organizations that have leadership buy-in but no clear starting point — teams tired of paying consultants for reports that sit in a drawer."
    },
    bgColor: "#f2f2f2",
  },
  {
    price: "$5k",
    duration: "8 weeks",
    title: "AI Pilot Sprint",
    subtitle: "See AI working inside your business — in 8 weeks.",
    sections: {
      whatItIs: "We take your Tier 1 roadmap and build it. One proof-of-concept deployed in your environment, tested against real use cases, with your team trained to run it. You walk away with working AI — not a presentation about it.",
      howWeDeliver: [
        "Everything in AI Readiness to Roadmap",
        "Design and deployment of one proof-of-concept AI system",
        "Real-world testing and validation before handover",
        "2-hour team training on operation and maintenance",
        "Deliverable: Working pilot + training session"
      ],
      whoThisServes: "Teams ready to move beyond planning — organizations that need a working proof-of-concept to build internal confidence and justify further investment."
    },
    bgColor: "#e5e5e5",
  },
  {
    price: "$10k – $15k",
    duration: "6 months",
    title: "6-Month AI Implementation",
    subtitle: "Full AI integration — with your people owning it at the end.",
    sections: {
      whatItIs: "A complete AI deployment using our Human-Centric AI Integration Framework (HCAIF). We build the system, manage the change, train your team, and ensure adoption — so the technology actually gets used, not abandoned.",
      howWeDeliver: [
        "Full HCAIF-driven implementation across your chosen workflows",
        "Custom AI systems deployed and integrated into your infrastructure",
        "Change management and cultural adoption support throughout",
        "Embedded team training and knowledge transfer",
        "Deliverable: Deployed AI solution + change management"
      ],
      whoThisServes: "Organizations committed to AI at scale — leaders who understand that deployment without adoption is just expensive software gathering dust."
    },
    bgColor: "#e2ddda",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
        AI Engagement Services
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-base-700 mt-4"
      >
        Three ways to engage — each one built around a specific outcome, not a generic consulting package. Pick the tier that matches where you are today.
      </Text>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      {
        pillars.map((pillar) => (
          <div class="flex-1 flex flex-col rounded-lg overflow-hidden transition-shadow duration-300 hover:shadow-xl">

            {/* Section 1 — orange: title, pricing, right for you if */}
            <div class="p-8" style="background-color: #E65100;">
              <Text tag="h3" variant="textXL" class="text-white font-bold mb-3">
                {pillar.title}
              </Text>
              <div class="flex items-baseline gap-3 mb-6">
                <span class="text-2xl font-bold font-display text-white">{pillar.price}</span>
                <span class="text-sm text-white/70">· {pillar.duration}</span>
              </div>
              <p class="text-xs text-white/70 uppercase font-semibold mb-2">Right For You If</p>
              <p class="text-sm text-white/90">{pillar.sections.whoThisServes}</p>
            </div>

            {/* Section 2 — light bg: what you get + what's included */}
            <div class="p-8 flex flex-col gap-6 flex-1" style={`background-color: ${pillar.bgColor}`}>
              <div>
                <p class="text-xs text-base-500 uppercase font-semibold mb-2">What You Get</p>
                <Text tag="p" variant="textSM" class="text-base-700">
                  {pillar.sections.whatItIs}
                </Text>
              </div>
              <div>
                <p class="text-xs text-base-500 uppercase font-semibold mb-2">What's Included</p>
                <ul class="space-y-1">
                  {pillar.sections.howWeDeliver.map((item) => (
                    <li class="text-sm text-base-700">• {item}</li>
                  ))}
                </ul>
              </div>
            </div>

          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
