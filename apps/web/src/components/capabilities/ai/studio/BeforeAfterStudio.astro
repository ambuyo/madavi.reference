---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const beforeItems = [
  "Sales team spending 6+ hours weekly on proposal generation and follow-ups",
  "Customer support drowning in repetitive tier-1 inquiries that could be automated",
  "Data trapped in disconnected systems requiring manual extraction and reconciliation",
  "Strategic initiatives delayed because teams are consumed by operational busywork",
];

const afterItems = [
  "Automated proposal systems generating customized documents in minutes with human oversight",
  "AI agents handling 70%+ of routine inquiries, escalating complex cases to human experts",
  "Integrated data pipelines providing real-time dashboards without manual intervention",
  "Teams reallocated to revenue-generating and strategic work that requires human judgment",
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-8">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
      </Text>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 lg:p-12"
      style="background-color: #FCF7F5"
    >
      <div class="rounded p-12" style="background-color: #FFB300">
        <Text
          tag="h3"
          variant="textXL"
          class="text-white font-semibold mb-6"
        >
          Before
        </Text>
        <ul class="space-y-4">
          {
            beforeItems.map((item) => (
              <li class="flex gap-3">
                <span class="text-white flex-shrink-0">•</span>
                <Text tag="p" variant="textBase" class="text-white">
                  {item}
                </Text>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="rounded p-12" style="background-color: #E65100">
        <Text
          tag="h3"
          variant="textXL"
          class="text-white font-semibold mb-6"
        >
          After
        </Text>
        <ul class="space-y-4">
          {
            afterItems.map((item) => (
              <li class="flex gap-3">
                <span class="text-white flex-shrink-0">•</span>
                <Text tag="p" variant="textBase" class="text-white">
                  {item}
                </Text>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Wrapper>
</section>
