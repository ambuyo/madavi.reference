---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";

const pillars = [
  {
    title: "Audit & Architecture",
    subtitle: "The building blocks",
    sections: {
      whatItIs: "We map your current systems, identify integration points, and design AI solutions that fit your actual infrastructure—not theoretical ideals. You get a technical blueprint that accounts for your data quality, system constraints, and team capabilities.",
      howWeDeliver: [
        "System mapping and assessment across your infrastructure",
        "Integration point identification and analysis",
        "Technical blueprint design tailored to your constraints",
        "Data quality and readiness assessment"
      ],
      whoThisServes: "Organizations that need a clear, realistic roadmap before committing to implementation—teams that want architecture grounded in their actual environment, not theory."
    },
    bgColor: "#E65100",
  },
  {
    title: "Build & Test",
    subtitle: "The Interior Design",
    sections: {
      whatItIs: "We develop custom agents, agentic workflows, and automation systems. Every deployment is tested against real use cases before going live. You see working prototypes, not wireframes. We iterate based on actual performance, not assumptions.",
      howWeDeliver: [
        "Custom agent and workflow development for your use cases",
        "Real-world testing and validation before go-live",
        "Working prototypes you can evaluate and refine",
        "Iterative improvements based on actual performance data"
      ],
      whoThisServes: "Teams ready to move from planning to building—organizations that want to see working systems and iterate based on real results."
    },
    bgColor: "#FFB300",
  },
  {
    title: "Deploy & Transfer",
    subtitle: "The Handoff",
    sections: {
      whatItIs: "We implement the system, train your team, and hand over operational control. You own the technology. We ensure you can run it. Includes documentation, runbooks, and direct training—not generic tutorials.",
      howWeDeliver: [
        "System implementation and deployment in your environment",
        "Team training on operation and maintenance",
        "Complete documentation and runbooks",
        "Direct knowledge transfer ensuring you own the technology"
      ],
      whoThisServes: "Organizations ready for go-live who need to take full operational control—teams that want hands-on support to ensure successful ownership of their systems."
    },
    bgColor: "bg-accent-700",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
        Our Approach
      </Text>

    </div>

    <div class="flex flex-col lg:flex-row gap-0 rounded-lg overflow-hidden">
      {
        pillars.map((pillar) => (
          <div class={`flex-1 p-8 lg:p-12 flex flex-col justify-between text-white ${pillar.bgColor.startsWith('#') ? '' : pillar.bgColor}`} style={pillar.bgColor.startsWith('#') ? `background-color: ${pillar.bgColor}` : ''}>
            <div class="text-left">
              <Text
                tag="h3"
                variant="textXL"
                class="text-white font-semibold mb-2"
              >
                {pillar.title}
              </Text>
              <Text
                tag="p"
                variant="textSM"
                class="text-white/80 mb-6 italic"
              >
                {pillar.subtitle}
              </Text>

              <div class="space-y-4">
                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    What It Is
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class="text-white/90"
                  >
                    {pillar.sections.whatItIs}
                  </Text>
                </div>

                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    How We Deliver
                  </Text>
                  <ul class="space-y-1">
                    {pillar.sections.howWeDeliver.map((item) => (
                      <li class="text-sm text-white/90">• {item}</li>
                    ))}
                  </ul>
                </div>

                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    Who This Serves
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class="text-white/90"
                  >
                    {pillar.sections.whoThisServes}
                  </Text>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
