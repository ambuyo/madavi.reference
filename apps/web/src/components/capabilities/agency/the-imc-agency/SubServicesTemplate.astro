---
import { Image } from "astro:assets";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Props {
  heading: string;
  subheading: string;
  image?: any;
  services: Array<{
    title: string;
    description: string;
    icon?: any;
  }>;
  bgColor?: string;
  accentColor?: string;
}

const {
  heading,
  subheading,
  image,
  services,
  bgColor = "#C85A3A",
  accentColor = "#C85A3A",
} = Astro.props;
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="rounded-3xl overflow-hidden" style={`background-color: ${bgColor}`}>
      {/* Header Section */}
      <div class="p-8 lg:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-center">
          <div class="lg:col-span-3">
            <Kicker variant="light" class="mb-4 text-white/90">Our Services</Kicker>
            <Text
              tag="h2"
              variant="displayLG"
              class="text-white font-display font-bold text-balance"
            >
              {heading}
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="text-white mt-6 text-balance"
            >
              {subheading}
            </Text>
          </div>
          {image && (
            <div class="lg:col-span-1 flex justify-center lg:justify-end">
              <Image
                src={image}
                alt="Services"
                width={600}
                height={400}
                loading="eager"
                decoding="async"
                class="max-w-full h-auto"
              />
            </div>
          )}
        </div>
      </div>

      {/* Services Cards */}
      <div class="px-8 lg:px-12 pb-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {services.map((service) => (
            <div class="bg-white rounded-2xl overflow-hidden">
              {service.icon && (
                <div class="w-full h-52 overflow-hidden bg-gray-200">
                  <Image
                    src={service.icon}
                    alt={service.title}
                    width={300}
                    height={200}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="p-8">
                <Text
                  tag="h3"
                  variant="textBase"
                  class="font-semibold mb-4"
                  style={`color: ${accentColor}`}
                >
                  {service.title}
                </Text>
                <hr class="border-t border-base-200 mb-4" />
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-base-600"
                >
                  {service.description}
                </Text>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Wrapper>
</section>
