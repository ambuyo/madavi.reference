---
// Assets
import { Image } from "astro:assets";
import featuredImage from "@/images/services/IMC Banner 1.jpg";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Props {
  kicker: string;
  heading: string;
  ctaText: string;
  ctaHref: string;
  ctaButtonLabel: string;
  models: Array<{ title: string; duration: string; description: string }>;
}
const { kicker, heading, ctaText, ctaHref, ctaButtonLabel, models } = Astro.props;
---

<section style="background-color: #FAF3E8;">
  <Wrapper variant="standard" class="py-16 lg:py-24">
    <div class="text-center mb-12">
      <Kicker variant="default">{kicker}</Kicker>
      <Text tag="h2" variant="displayLG" class="text-base-900 font-display font-bold mt-4">
        {heading}
      </Text>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch">
      <div class="flex flex-col gap-6">
        {models.slice(0, 2).map((item) => (
          <div class="bg-white/60 rounded-2xl p-8 flex flex-col min-h-[280px]">
            <div>
              <Text tag="h3" variant="textXL" class="text-base-900 font-display font-medium">
                {item.title}
              </Text>
              <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wide mt-1">
                {item.duration}
              </Text>
            </div>
            <Text tag="p" variant="textSM" class="text-base-600 mt-6">
              {item.description}
            </Text>
          </div>
        ))}
      </div>

      <div class="relative rounded-2xl overflow-hidden min-h-[580px] flex flex-col justify-end">
        <Image
          src={featuredImage}
          alt="Engagement Models"
          width={800}
          height={1000}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/50 to-transparent p-8 pt-24">
          <Text tag="p" variant="textBase" class="text-white mb-6">
            {ctaText}
          </Text>
          <Button variant="muted" size="sm" isLink={true} href={ctaHref} class="w-fit">
            {ctaButtonLabel}
          </Button>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        {models.slice(2, 4).map((item) => (
          <div class="bg-white/60 rounded-2xl p-8 flex flex-col min-h-[280px]">
            <div>
              <Text tag="h3" variant="textXL" class="text-base-900 font-display font-medium">
                {item.title}
              </Text>
              <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wide mt-1">
                {item.duration}
              </Text>
            </div>
            <Text tag="p" variant="textSM" class="text-base-600 mt-6">
              {item.description}
            </Text>
          </div>
        ))}
      </div>
    </div>
  </Wrapper>
</section>
