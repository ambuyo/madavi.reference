---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

interface Props {
  heading: string;
  pillars: Array<{ title: string; content: string; bgColor: string }>;
}
const { heading, pillars } = Astro.props;
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text tag="h2" variant="displayMD" class="text-base-900 text-balance font-display">
        {heading}
      </Text>
    </div>
    <div class="flex flex-col lg:flex-row gap-0 rounded-lg overflow-hidden">
      {pillars.map((pillar) => (
        <div
          class="flex-1 pl-8 lg:pl-12 pr-8 lg:pr-12 py-8 lg:py-12 flex flex-col justify-between text-white"
          style={`background-color: ${pillar.bgColor}`}
        >
          <div class="text-left">
            <Text tag="h3" variant="textXL" class="text-white font-semibold mb-6 text-left">
              {pillar.title}
            </Text>
            <Text tag="p" variant="textSM" class="text-white/90 text-left">
              {pillar.content}
            </Text>
          </div>
        </div>
      ))}
    </div>
  </Wrapper>
</section>
