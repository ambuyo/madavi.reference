---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";

import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const paths = [
  {
    title: "What This Is",
    description:
      "The Agency is Madavi's brand and content arm. We handle how you position yourself, what you say, and how you say it. From brand strategy to daily social posts, we create the communications infrastructure that supports your business goals.",
  },
  {
    title: "Why It Exists",
    description:
      "Most organizations have something valuable to offer but can't articulate it clearly. They post content inconsistently, struggle with brand recognition, and watch competitors dominate conversations they should own. The Agency exists because effective communication requires dedicated capacity—strategy to determine what matters, systems to execute consistently, and expertise to do both well.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="p-8 lg:p-12" style="background-color: #FCF7F5;">
      <div class="w-3/4">
        <Text
          tag="h2"
          variant="displayMD"
          class="text-base-900 text-balance font-display"
        >
The AI Agency is here.
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-700 lg:text-pretty lg:col-span-2 mt-4"
        >
We build the systems your strategy requires.

        </Text>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-12"
      >
        {
          paths.map((path) => (
            <div class="relative group bg-white flex flex-col overflow-hidden p-8 gap-24 lg:gap-62 h-full justify-between">
              <div>
                <Text
                  tag="h3"
                  variant="textXL"
                  class="mb-4 text-base-900 font-semibold"
                >
                  {path.title}
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-base-600 mt-4 text-pretty"
                >
                  {path.description}
                </Text>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
