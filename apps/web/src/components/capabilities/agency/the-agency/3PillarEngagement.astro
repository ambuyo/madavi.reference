---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";

const pillars = [
  {
    title: "Position",
    subtitle: "Strategy & clarity",
    sections: {
      whatItIs: "We define how you fit in your market. What you stand for, who you serve, what makes you different. Research-backed positioning that guides every communication decision.",
      howWeDeliver: [
        "Market positioning research and competitive analysis",
        "Differentiation strategy development",
        "Brand voice and values definition",
        "Communication strategy framework"
      ],
      whoThisServes: "Organizations that need clear positioning to stand out—teams ready to define their unique value and guide all future communications."
    },
    bgColor: "#1A3A52",
  },
  {
    title: "Create",
    subtitle: "Content & execution",
    sections: {
      whatItIs: "We build your content systems. Blogs that rank, social media that engages, PR that builds credibility, brand identities that communicate at first glance. Consistent execution across all channels.",
      howWeDeliver: [
        "Content strategy and editorial calendar development",
        "Blog creation and SEO optimization",
        "Social media management and strategy",
        "PR outreach and media relations",
        "Brand identity and visual system design"
      ],
      whoThisServes: "Brands ready to scale their presence—teams that need consistent, high-quality content across all channels to build audience and credibility."
    },
    bgColor: "#E65100",
  },
  {
    title: "Maintain",
    subtitle: "Growth & consistency",
    sections: {
      whatItIs: "We manage your brand equity. Guidelines that keep identity consistent, performance tracking that shows what's working, strategic refinements when markets shift. Your brand strengthens over time instead of fragmenting.",
      howWeDeliver: [
        "Brand guideline development and enforcement",
        "Content performance analytics and reporting",
        "Market response monitoring and adaptation",
        "Strategic refinements based on performance data",
        "Long-term brand equity management"
      ],
      whoThisServes: "Established brands seeking sustained growth—organizations that want strategic oversight ensuring consistent brand identity and measurable results over time."
    },
    bgColor: "#2A7F62",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div class="mb-12 max-w-2xl">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-base-900 text-balance font-display"
      >
        Our Approach
      </Text>

    </div>

    <div class="flex flex-col lg:flex-row gap-0 rounded-lg overflow-hidden">
      {
        pillars.map((pillar) => (
          <div class={`flex-1 p-8 lg:p-12 flex flex-col justify-between text-white ${pillar.bgColor.startsWith('#') ? '' : pillar.bgColor}`} style={pillar.bgColor.startsWith('#') ? `background-color: ${pillar.bgColor}` : ''}>
            <div class="text-left">
              <Text
                tag="h3"
                variant="textXL"
                class="text-white font-semibold mb-2"
              >
                {pillar.title}
              </Text>
              <Text
                tag="p"
                variant="textSM"
                class="text-white/80 mb-6 italic"
              >
                {pillar.subtitle}
              </Text>

              <div class="space-y-4">
                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    What It Is
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class="text-white/90"
                  >
                    {pillar.sections.whatItIs}
                  </Text>
                </div>

                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    How We Deliver
                  </Text>
                  <ul class="space-y-1">
                    {pillar.sections.howWeDeliver.map((item) => (
                      <li class="text-sm text-white/90">• {item}</li>
                    ))}
                  </ul>
                </div>

                <div>
                  <Text
                    tag="p"
                    variant="textXS"
                    class="text-white/70 uppercase font-semibold mb-2"
                  >
                    Who This Serves
                  </Text>
                  <Text
                    tag="p"
                    variant="textSM"
                    class="text-white/90"
                  >
                    {pillar.sections.whoThisServes}
                  </Text>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
