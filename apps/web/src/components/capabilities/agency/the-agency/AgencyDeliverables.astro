---
// Assets
import { Image } from "astro:assets";
import talk from "@/images/assets/talk.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const features = [
  {
    title: "Strategic Foundation",
    items: [
      "Brand positioning statement defining your market fit",
      "Messaging framework your entire team uses",
      "Content strategy tied to business goals",
      "Competitive analysis showing white space opportunities",
    ],
  },
  {
    title: "Execution Systems",
    items: [
      "SEO-optimized content published on schedule",
      "Social media managed across relevant platforms",
      "Professional brand identity with comprehensive guidelines",
      "PR outreach generating third-party credibility",
    ],
  },
  {
    title: "Performance Visibility",
    items: [
      "Monthly reporting on content performance",
      "Brand health tracking showing awareness and perception trends",
      "Clear metrics connecting communication to business outcomes",
      "Quarterly strategy reviews ensuring execution stays aligned",
    ],
  },
];
---

<section>
  <Wrapper variant="standard" class="py-12">
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 lg:p-12 bg-base-50"
    >
      <div class="flex flex-col">
        <div>
          <Text
            tag="h2"
            variant="displayMD"
            class="text-base-950 text-balance font-medium tracking-tight font-display mt-8"
          >
            What you get
          </Text>
     
        </div>
        <div class="grid grid-cols-1 gap-y-12 mt-12">
          {
            features.map((feature) => (
              <div>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="text-base-900 font-display"
                >
                  {feature.title}
                </Text>
                <ul class="mt-3 space-y-2">
                  {feature.items.map((item) => (
                    <li class="flex gap-2">
                      <span class="text-base-600 flex-shrink-0">•</span>
                      <Text
                        tag="p"
                        variant="textSM"
                        class="text-base-600 text-pretty"
                      >
                        {item}
                      </Text>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
      <Image
        src={talk}
        alt="Image"
        width={800}
        height={1440}
        loading="eager"
        decoding="async"
        class="size-full object-cover object-center aspect-square"
      />
    </div>
  </Wrapper>
</section>
