---
import LegalLayout from "@/layouts/LegalLayout.astro";
import { getInfoPages, getInfoPageBySlug } from "@/lib/data";

export async function getStaticPaths() {
  const infoPages = await getInfoPages();
  return infoPages.map((page) => ({
    params: { slug: page.slug },
  }));
}

const { slug } = Astro.params;
const page = await getInfoPageBySlug(slug!);
if (!page) {
  return Astro.redirect("/404");
}
---

<LegalLayout frontmatter={page.data}>
  <div set:html={page.body} />
</LegalLayout>
