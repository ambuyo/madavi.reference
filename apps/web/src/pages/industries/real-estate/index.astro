---
export const prerender = true;
import { getCollection } from "astro:content";
import IndustryLayout from "@/layouts/IndustryLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ThreeTierProblems from "@/components/industries/3TierProblems.astro";
import IndustryValueProposition from "@/components/industries/IndustryValueProposition.astro";
import BenefitsSection from "@/components/industries/BenefitsSection.astro";
import IndustryROI from "@/components/industries/IndustryROI.astro";
import IndustryBlogPreview from "@/components/industries/IndustryBlogPreview.astro";
import IndustryFAQs from "@/components/industries/IndustryFAQs.astro";

const industries = await getCollection("industries");
const industryContent = industries.find((ind: any) => ind.id === "real-estate");
const industryData = industryContent?.data || {};

const heroColor = industryData.hero?.backgroundColor || "#1B4965";

const seo = {
  title: industryData.seo?.title || "AI For Real Estate | Brokerage & Property Management Automation",
  description: industryData.seo?.description || "AI systems for real estate that reduce transaction admin, automate property marketing, and scale client communication.",
  type: "website" as const,
};
---

<IndustryLayout seo={seo}>
  <section style={`background-color: ${heroColor};`} class="text-white">
    <Wrapper variant="standard" class="py-24 lg:py-32">
      <div class="max-w-3xl">
        <Text
          tag="p"
          variant="textXS"
          class="text-white/80 tracking-wide uppercase"
        >
          {industryData.hero?.kicker || "AI FOR REAL ESTATE"}
        </Text>
        <Text
          tag="h1"
          variant="displayLG"
          class="text-white font-display font-bold mt-2"
        >{industryData.hero?.headline || "Close More Deals Without More Agents"}</Text>
        <Text
          tag="p"
          variant="textLG"
          class="text-white/90 mt-6"
        >{industryData.hero?.description || "AI systems that accelerate transaction workflows, automate property marketing, and scale client communication."}</Text>
      </div>
    </Wrapper>
  </section>

  <IndustryValueProposition
    title={industryData.valueProposition?.title}
    description={industryData.valueProposition?.description}
    narrativeParagraphs={industryData.valueProposition?.narrativeParagraphs || []}
    heroImage={industryData.hero?.image}
  />

  <ThreeTierProblems
    title={industryData.threeTierProblems?.title}
    description={industryData.threeTierProblems?.description}
    tiers={industryData.threeTierProblems?.tiers || []}
  />

  <BenefitsSection
    number={industryData.benefits?.number}
    title={industryData.benefits?.title}
    subtitle={industryData.benefits?.subtitle}
    benefits={industryData.benefits?.benefitItems || []}
    deliveryItems={industryData.benefits?.deliveryItems || []}
  />

  <IndustryROI
    title={industryData.roi?.title}
    before={{
      title: industryData.roi?.beforeSection?.title,
      stats: industryData.roi?.beforeSection?.stats || []
    }}
    after={{
      title: industryData.roi?.afterSection?.title,
      stats: industryData.roi?.afterSection?.stats || []
    }}
    investment={industryData.roi?.investment}
    netBenefit={industryData.roi?.netBenefit}
    roiPercentage={industryData.roi?.roiPercentage}
    secondaryBenefits={industryData.roi?.secondaryBenefits || []}
  />

  <IndustryBlogPreview category={industryData.blog?.category || "real-estate"} />

  <IndustryFAQs
    title={industryData.faqs?.title}
    description={industryData.faqs?.description}
    faqSlug={industryData.faqs?.slug}
  />
</IndustryLayout>
