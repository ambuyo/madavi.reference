---
// Fundations
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import IndustryNav from "@/components/industries/IndustryNav.astro";
import Footer from "@/components/global/Footer.astro";

const seo = {
  title: "Legal Industry AI Solutions",
  description: "Specialized AI consulting and digital transformation for law firms and legal enterprises.",
  type: "website" as const,
};
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead seo={seo} />
  </head>
  <body class="flex flex-col bg-white min-h-dvh">
    <IndustryNav />
    <main class="grow pt-24"></main>
    <Footer />
  </body>
</html>
