---
export const prerender = true;
import BaseLayout from "@/layouts/BaseLayout.astro";

import TapThriveHero        from "@/components/solutions/tapthrive/TapThriveHero.astro";
import TapObjectionCrusher  from "@/components/solutions/tapthrive/TapObjectionCrusher.astro";
import TapValueStatement    from "@/components/solutions/tapthrive/TapValueStatement.astro";
import TapProblemStatement  from "@/components/solutions/tapthrive/TapProblemStatement.astro";
import TapUseCases          from "@/components/solutions/tapthrive/TapUseCases.astro";
import TapHowItWorks        from "@/components/solutions/tapthrive/TapHowItWorks.astro";
import TapComparisonTable   from "@/components/solutions/tapthrive/TapComparisonTable.astro";
import WhyTapWorks          from "@/components/solutions/tapthrive/WhyTapWorks.astro";
import TapThriveBenefits    from "@/components/solutions/tapthrive/TapThriveBenefits.astro";
import TapThriveTestimonials from "@/components/solutions/tapthrive/TapThriveTestimonials.astro";
import TapThrivePricing     from "@/components/solutions/tapthrive/TapThrivePricing.astro";
import TapThriveMultiLocation from "@/components/solutions/tapthrive/TapThriveMultiLocation.astro";
import TapGMBSetup          from "@/components/solutions/tapthrive/TapGMBSetup.astro";
import TapFAQs              from "@/components/solutions/tapthrive/TapFAQs.astro";
import TapThriveBlog        from "@/components/solutions/tapthrive/TapThriveBlog.astro";
import TapThriveCTA         from "@/components/solutions/tapthrive/TapThriveCTA.astro";
---

<BaseLayout
  title="TapThrive — NFC & QR Google Review Cards for Kenyan Businesses | Madavi"
  description="TapThrive helps Kenyan businesses collect more Google reviews automatically — NFC tap or QR scan, WhatsApp follow-up, and complaint filtering in one simple system. By Madavi."
  canonical="https://madavi.co/solutions/tapthrive"
  keywords={["NFC reviews Kenya", "QR review card Nairobi", "Google reviews automation", "WhatsApp follow-up reviews", "TapThrive", "Madavi", "reputation management Kenya"]}
>
  <TapThriveHero />
  <TapObjectionCrusher />
  <TapValueStatement />
  <TapProblemStatement />
  <TapUseCases />
  <TapHowItWorks />
  <TapComparisonTable />
  <WhyTapWorks />
  <TapThriveBenefits />
  <TapThriveTestimonials />
  <TapThrivePricing />
  <TapThriveMultiLocation />
  <TapGMBSetup />
  <TapFAQs />
  <TapThriveBlog />
  <TapThriveCTA />
</BaseLayout>
