---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";
// Sanity
import { getReports } from "@/lib/sanity/reports";

const allReports = await getReports();
const reportsPerPage = 8; // 2 rows of 4 columns
const currentPage = parseInt(Astro.url.searchParams.get("page") || "1");
const totalPages = Math.ceil(allReports.length / reportsPerPage);
const startIndex = (currentPage - 1) * reportsPerPage;
const endIndex = startIndex + reportsPerPage;
const reports = allReports.slice(startIndex, endIndex);

// Validate page number
if (currentPage < 1 || currentPage > totalPages) {
  return Astro.redirect("/resources/reports?page=1");
}
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-32">
      <div class="max-w-xl">
        <Text
          tag="span"
          variant="textXS"
          class="uppercase font-medium text-accent-700"
        >
          Resources
        </Text>

        <Text
          tag="h1"
          variant="displayXL"
          class="text-base-900 mt-12 tracking-tight font-display text-balance"
        >
          Reports & Documents
        </Text>

        <Text tag="p" variant="textLG" class="text-base-600 mt-4 text-balance">
          Access official reports, financial documents, meeting minutes, and strategic planning resources.
        </Text>
      </div>

      <div class="space-y-8 lg:space-y-24 mt-12 lg:mt-24">
        {
          reports.length > 0 ? (
            reports.map((report, index) => {
              const pubDate = new Date(report.publicationDate).toLocaleDateString(
                "en-US",
                {
                  year: "numeric",
                  month: "short",
                }
              ).toUpperCase();
              return (
                <article class="relative group bg-base-50 grid grid-cols-1 lg:grid-cols-5 gap-x-4 items-start">
                  {report.reportCoverImage?.asset?.url && (
                    <div class="col-span-1 lg:col-span-2 w-full h-full">
                      <img
                        src={report.reportCoverImage.asset.url}
                        alt={report.reportCoverImage.alt || report.name}
                        loading="eager"
                        decoding="async"
                        class="w-full h-full object-contain"
                      />
                    </div>
                  )}
                  <div class="lg:col-span-3 p-[20px] flex flex-col gap-8">
                    <div>
                      <Text
                        tag="p"
                        variant="textXS"
                        class="uppercase font-medium text-accent-700 tracking-wider"
                      >
                        {report.industry} <span class="mx-2">|</span> {pubDate}
                      </Text>
                      <a href={`/resources/reports/${report.slug.current}`} class="inline-block mt-4 hover:text-accent-700 transition-colors">
                        <Text
                          tag="h2"
                          variant="displaySM"
                          class="text-base-900 font-display text-[26px]"
                        >
                          {report.name}
                        </Text>
                      </a>
                    </div>
                    <Text
                      tag="p"
                      variant="textLG"
                      class="text-base-900 leading-relaxed text-[16px]"
                    >
                      {report.summary}
                    </Text>
                  </div>
                </article>
              );
            })
          ) : (
            <Text tag="p" variant="textBase" class="text-base-600">
              No reports available at the moment. Check back soon!
            </Text>
          )
        }
      </div>

      {/* Pagination */}
      {totalPages > 1 && (
        <div class="flex items-center justify-center gap-4 mt-20">
          {currentPage > 1 && (
            <Button
              isLink
              href={`/resources/reports?page=${currentPage - 1}`}
              variant="muted"
              size="sm"
            >
              ← Previous
            </Button>
          )}

          <div class="flex items-center gap-2">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
              <Button
                isLink
                href={`/resources/reports?page=${page}`}
                variant={page === currentPage ? "default" : "muted"}
                size="xs"
                class={page === currentPage ? "pointer-events-none" : ""}
              >
                {page}
              </Button>
            ))}
          </div>

          {currentPage < totalPages && (
            <Button
              isLink
              href={`/resources/reports?page=${currentPage + 1}`}
              variant="muted"
              size="sm"
            >
              Next →
            </Button>
          )}
        </div>
      )}
    </Wrapper>
  </section>
</BaseLayout>
