---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

export async function getStaticPaths() {
  const faqEntries = await getCollection("faqs");

  // Get unique slugs
  const uniqueSlugs = new Set(faqEntries.map(faq => faq.data.slug));

  return Array.from(uniqueSlugs).map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

// Fetch FAQs with this slug
const allFaqs = await getCollection("faqs");
const faqsWithSlug = allFaqs.filter(faq => faq.data.slug === slug);

if (faqsWithSlug.length === 0) {
  return new Response("Not found", { status: 404 });
}

// Combine all FAQs with the same slug
const combined = faqsWithSlug.reduce((acc, faq) => {
  if (!acc.title) {
    acc.title = faq.data.title;
    acc.description = faq.data.description;
    acc.seo = faq.data.seo;
    acc.schema = faq.data.schema;
    acc.faqs = [];
  }
  if (faq.data.faqs) {
    acc.faqs = acc.faqs.concat(faq.data.faqs);
  }
  return acc;
}, {} as any);

const seoMeta = {
  title: combined.seo?.title || combined.title,
  description: combined.seo?.description || combined.description,
  keywords: combined.seo?.keywords?.join(", "),
  type: "website" as const,
};
---

<BaseLayout seo={seoMeta}>
  <section>
    <Wrapper variant="standard" class="pb-12 pt-48">
      {/* Back Link */}
      <a href="/resources/faqs" class="inline-flex items-center text-accent-700 hover:text-accent-900 mb-8 transition-colors">
        <span class="mr-2">←</span>
        <span class="underline">Back to FAQs</span>
      </a>

      <div class="max-w-3xl">
        {/* Header */}
        <Text
          tag="h1"
          variant="displayMD"
          class="text-accent-800 font-display text-balance"
        >
          {combined.title}
        </Text>
        {combined.description && (
          <Text tag="p" variant="textLG" class="text-base-700 mt-6">
            {combined.description}
          </Text>
        )}

        {/* FAQ Items as Article */}
        <article class="mt-16 space-y-12 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-accent-800 [&_h3]:mt-6 [&_h3]:mb-3 [&_h4]:text-base [&_h4]:font-semibold [&_h4]:text-accent-700 [&_h4]:mt-4 [&_h4]:mb-2 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:space-y-2 [&_li]:text-base [&_p]:mb-4 [&_p]:text-base-700">
          {combined.faqs?.map((item: any, index: number) => (
            <div key={index} id={item.id} class="scroll-mt-24 space-y-4">
              <Text
                tag="h2"
                variant="displayXS"
                class="text-accent-800 font-display"
              >
                {item.question}
              </Text>

              <div class="text-base-700 space-y-4">
                <div set:html={item.fullAnswer} />
              </div>

              {index < combined.faqs.length - 1 && (
                <hr class="border-t border-base-300 mt-8" />
              )}
            </div>
          ))}
        </article>
      </div>
    </Wrapper>
  </section>

  {/* JSON-LD Schema */}
  {
    combined.schema && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(combined.schema)}
      />
    )
  }
</BaseLayout>
