---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

// Fetch all FAQs
const allFaqs = await getCollection("faqs");

// Get unique slugs and categorize them
const uniqueSlugs = new Map();
const industryKeywords = ["nonprofit", "healthcare", "retail", "law-firm"];
allFaqs.forEach((faq: any) => {
  const slug = faq.data.slug;
  if (!uniqueSlugs.has(slug)) {
    const isIndustry = industryKeywords.some(keyword => slug.includes(keyword));
    uniqueSlugs.set(slug, {
      slug: slug,
      title: faq.data.title,
      category: isIndustry ? "Industry FAQs" : "Capability FAQs"
    });
  }
});

// Group by category
const faqsByCategory = Array.from(uniqueSlugs.values()).reduce((acc: any, item) => {
  if (!acc[item.category]) {
    acc[item.category] = [];
  }
  acc[item.category].push(item);
  return acc;
}, {});

const categories = Object.keys(faqsByCategory).sort();
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pb-12 pt-48">
      <div class="max-w-3xl">
        <Text
          tag="h1"
          variant="displayMD"
          class="text-accent-800 font-display text-balance"
        >
          Frequently Asked Questions
        </Text>
        <Text tag="p" variant="textLG" class="text-base-700 mt-6">
          Find answers to common questions about AI implementation, industry-specific solutions, and our approach to digital transformation.
        </Text>

        {/* Category Links */}
        <div class="mt-16 space-y-12">
          {categories.map((category) => (
            <div>
              <Text
                tag="h2"
                variant="displayXS"
                class="text-accent-800 font-display mb-6"
              >
                {category}
              </Text>

              <div class="space-y-3">
                {faqsByCategory[category].map((item: any) => (
                  <a
                    href={`/resources/faqs/${item.slug}`}
                    class="block p-4 border border-base-300 rounded-lg hover:bg-base-50 hover:border-accent-600 transition-all group"
                  >
                    <Text
                      tag="h3"
                      variant="textBase"
                      class="text-accent-800 font-semibold group-hover:text-accent-900"
                    >
                      {item.title}
                    </Text>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
