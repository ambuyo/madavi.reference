---
export const prerender = true;
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Popular Pages Data
const popularPages = [
  {
    href: "/the-imc-agency",
    title: "The IMC Agency",
    description: "Integrated marketing communications built for modern brands",
  },
  {
    href: "/ai-studio",
    title: "The AI Studio",
    description: "AI-powered solutions to accelerate your business growth",
  },
  {
    href: "/about",
    title: "About",
    description: "Learn who we are and what drives us",
  },
  {
    href: "/blog",
    title: "Blog",
    description: "Insights, ideas, and industry perspectives",
  },
  {
    href: "/our-work",
    title: "Our Work",
    description: "Case studies and projects we're proud of",
  },
  {
    href: "/solutions",
    title: "Solutions",
    description: "Explore the full range of what we offer",
  },
];
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-12">
      <div class="max-w-2xl">
        <Kicker variant="default">Faq</Kicker>
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 text-balance font-medium tracking-tight mt-8 font-display"
        >
          404 - Page Not Found
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 lg:text-balance mt-4"
        >
          We apologize, but the page you're looking for doesn't exist. It may
          have been moved, deleted, or you may have mistyped the URL.
        </Text>
        <div class="flex flex-col lg:flex-row gap-2 mt-8">
          <Button variant="default" size="xs" isLink={true} href="/">
            Return Home
          </Button>
          <Button variant="muted" size="xs" isLink={true} href="/get-a-proposal">
            Contact Us
          </Button>
        </div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 mt-12 gap-2">
        {
          popularPages.map((page) => (
            <div class="relative group flex flex-col overflow-hidden gap-24 lg:gap-62 p-8 h-full justify-between" style="background-color: #FF5000;">
              <a href={page.href} class="inset-0 absolute z-10" />
              <div class="text-left">
                <Text
                  tag="h3"
                  variant="displayMD"
                  class="font-display"
                  style="color: #fff;"
                >
                  {page.title}
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="mt-4 text-pretty"
                  style="color: #fff; opacity: 0.85;"
                >
                  {page.description}
                </Text>
              </div>
              <Text
                tag="p"
                variant="textSM"
                class="uppercase font-medium mt-4"
                style="color: #fff;"
              >
                Read further
              </Text>
            </div>
          ))
        }
      </div>

      <div
        class="mt-8 pt-8 border-t border-base-100 flex flex-wrap gap-4 justify-between items-start"
      >
        <Text tag="p" variant="textSM" class="text-base-600">
          Need immediate assistance? Our team is here to help.
        </Text>
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        >
          <a
            href="tel:+254718735565"
            class="uppercase font-medium ext-base-900 hover:text-accent-400 text-sm"
          >
            (254) 718-735-565
          </a>
          <span class="hidden sm:block text-base-300">•</span>
          <a
            href="mailto:hi@madavi.co"
            class="uppercase font-medium ext-base-900 hover:text-accent-400 text-sm"
          >
            hi@madavi.co
          </a>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
