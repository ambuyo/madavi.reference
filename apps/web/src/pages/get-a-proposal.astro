---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const seo = {
  title: "Get a Proposal",
  description: "Request a custom proposal from Madavi. Let's discuss your AI transformation needs and how we can help grow your revenue.",
  type: "website" as const,
};
---
<BaseLayout seo={seo}>
  <section style="background-color: #005C66; color: white; padding: 80px 20px;">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-white font-bold mb-4"
          style="font-size: 48px;"
        >
          Get Your Free AI Audit
        </Text>
        <Text
          tag="p"
          variant="textLG"
          class="text-gray-200"
        >
          Discover how AI can transform your business. Get a <span class="font-bold">free AI audit</span> and a <span class="font-bold">custom proposal</span> from our experts.
        </Text>
      </div>

      <div class="grid gap-12 items-start" style="grid-template-columns: 60% 40%;">
        {/* Left Column - Form */}
        <div class="bg-white rounded-3xl text-gray-900" style="box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
          <div class="text-center" style="padding: 32px 32px 0 32px;">
              <Text
                tag="h2"
                variant="displayMD"
                class="text-gray-900 font-bold mb-2"
                style="font-size: 24px;"
              >
                Free AI Audit & Proposal
              </Text>
            </div>

            <div id="zf_div_2C1pgCsgILhEoe8UceVOVxcGTxQzVpG0Fi2BkDPf8FQ" style="padding: 0 32px 32px 32px;">
            </div>
          <script type="text/javascript">
          (function() {
          	try{
          		var f = document.createElement("iframe");

          			var ifrmSrc = 'https://forms.zohopublic.com/madavidigital1/form/AIAudit/formperma/2C1pgCsgILhEoe8UceVOVxcGTxQzVpG0Fi2BkDPf8FQ?zf_rszfm=1';


                  try{
          			if ( typeof ZFAdvLead != "undefined" && typeof zfutm_zfAdvLead != "undefined" ) {
          				for( var prmIdx = 0 ; prmIdx < ZFAdvLead.utmPNameArr.length ; prmIdx ++ ) {
          				    var utmPm = ZFAdvLead.utmPNameArr[ prmIdx ];
          				    utmPm = ( ZFAdvLead.isSameDomian && ( ZFAdvLead.utmcustPNameArr.indexOf(utmPm) == -1 ) ) ? "zf_" + utmPm : utmPm;
          				    var utmVal = zfutm_zfAdvLead.zfautm_gC_enc( ZFAdvLead.utmPNameArr[ prmIdx ] );
          				    if ( typeof utmVal !== "undefined" ) {
          				      if ( utmVal != "" ) {
          				        if(ifrmSrc.indexOf('?') > 0){
          				             ifrmSrc = ifrmSrc+'&'+utmPm+'='+utmVal;
          				        }else{
          				            ifrmSrc = ifrmSrc+'?'+utmPm+'='+utmVal;
          				        }
          				      }
          				    }
          				}
          			}
          			if ( typeof ZFLead !== "undefined" && typeof zfutm_zfLead !== "undefined" ) {
          				for( var prmIdx = 0 ; prmIdx < ZFLead.utmPNameArr.length ; prmIdx ++ ) {
          		        	var utmPm = ZFLead.utmPNameArr[ prmIdx ];
          		        	var utmVal = zfutm_zfLead.zfutm_gC_enc( ZFLead.utmPNameArr[ prmIdx ] );
          			        if ( typeof utmVal !== "undefined" ) {
          			          if ( utmVal != "" ){
          			            if(ifrmSrc.indexOf('?') > 0){
          			              ifrmSrc = ifrmSrc+'&'+utmPm+'='+utmVal;//No I18N
          			            }else{
          			              ifrmSrc = ifrmSrc+'?'+utmPm+'='+utmVal;//No I18N
          			            }
          			          }
          			        }
          		      	}
          			}
          			if (!((new RegExp("[?&]referrername=")).test(ifrmSrc))) {
                      var rfr = window.location.href;

                      try {
                          rfr = window.self !== window.top ?
                              window.top.location.href :
                              (/^https?:\/\/[\w.-]+\.[a-zA-Z]{2,}/i.test(rfr) ? rfr : "");
                      } catch (e) {}

                      if (rfr && rfr !== "") {
                          if (rfr.length > 1800) {
                              var queryIndex = rfr.indexOf('?');
                              if (queryIndex > -1) {
                                  rfr = rfr.substring(0, queryIndex);
                              }
                              if (rfr.length > 1800) {
                                  rfr = rfr.substring(0, 1800);
                              }
                          }
                          ifrmSrc += ((ifrmSrc.indexOf('?') > 0) ? '&' : '?') + 'referrername=' + encodeURIComponent(rfr);
                      }
                  }
          		}catch(e){}


          		f.src = ifrmSrc;
          		f.style.border="none";
          		f.style.height="1399px";
          		f.style.width="100%";
          		f.style.transition="all 0.5s ease";
          		f.setAttribute("aria-label", 'AI Audit : Get A Proposal Madavi');

          		var d = document.getElementById("zf_div_2C1pgCsgILhEoe8UceVOVxcGTxQzVpG0Fi2BkDPf8FQ");
          		d.appendChild(f);
          		window.addEventListener('message', function (){
          			var evntData = event.data;
          			if( evntData && evntData.constructor == String ){
          				var zf_ifrm_data = evntData.split("|");
          				if ( zf_ifrm_data.length == 2 || zf_ifrm_data.length == 3 ) {
          					var zf_perma = zf_ifrm_data[0];
          					var zf_ifrm_ht_nw = ( parseInt(zf_ifrm_data[1], 10) + 15 ) + "px";
          					var iframe = document.getElementById("zf_div_2C1pgCsgILhEoe8UceVOVxcGTxQzVpG0Fi2BkDPf8FQ").getElementsByTagName("iframe")[0];
          					if ( (iframe.src).indexOf('formperma') > 0 && (iframe.src).indexOf(zf_perma) > 0 ) {
          						var prevIframeHeight = iframe.style.height;
          						var zf_tout = false;
          						if( zf_ifrm_data.length == 3 ) {
          						    iframe.scrollIntoView();
          						    zf_tout = true;
          						}

          						if ( prevIframeHeight != zf_ifrm_ht_nw ) {
          							if( zf_tout ) {
          							    setTimeout(function(){
          							        iframe.style.height = zf_ifrm_ht_nw;
          							    },500);
          							} else {
          							    iframe.style.height = zf_ifrm_ht_nw;
          							}
          						}
          					}
          				}
          			}
          		}, false);
              }catch(e){}


          })();
          </script>
        </div>

        {/* Right Column - Benefits */}
        <div class="text-white">
          <Text
            tag="h3"
            variant="displayMD"
            class="text-white font-bold mb-8"
          >
            What You'll Get:
          </Text>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-teal-400 text-gray-900 font-bold">
                  ✓
                </div>
              </div>
              <div>
                <Text
                  tag="h4"
                  variant="textLG"
                  class="text-white font-bold"
                >
                  Comprehensive AI Audit
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-gray-300 mt-2"
                >
                  We'll analyze your current marketing, identify AI opportunities, and assess your readiness for transformation. No obligation, completely free.
                </Text>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-teal-400 text-gray-900 font-bold">
                  ✓
                </div>
              </div>
              <div>
                <Text
                  tag="h4"
                  variant="textLG"
                  class="text-white font-bold"
                >
                  Custom Strategy Proposal
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-gray-300 mt-2"
                >
                  Receive a personalized proposal with AI-powered recommendations, implementation timeline, and expected outcomes tailored to your business.
                </Text>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-8 w-8 rounded-full bg-teal-400 text-gray-900 font-bold">
                  ✓
                </div>
              </div>
              <div>
                <Text
                  tag="h4"
                  variant="textLG"
                  class="text-white font-bold"
                >
                  Expert Consultation
                </Text>
                <Text
                  tag="p"
                  variant="textBase"
                  class="text-gray-300 mt-2"
                >
                  Connect with our AI strategists to discuss your audit results, answer questions, and explore how AI can drive measurable growth for your business.
                </Text>
              </div>
            </div>
          </div>

          <div class="mt-12 pt-8 border-t border-gray-600">
            <Text
              tag="p"
              variant="textBase"
              class="text-gray-300 italic mb-4"
            >
              "Working with Madavi gave us a clear roadmap for AI implementation that directly impacted our bottom line"
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="text-white font-bold"
            >
              Leading Tech Company
            </Text>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
