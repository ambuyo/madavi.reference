---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Kicker from "@/components/fundations/elements/Kicker.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import SingleWorkCard from "@/components/cases/SingleWorkCard.astro";
// Data
import { getOurWork } from "@/lib/data";
const allCaseStudies = (await getOurWork()).sort((a, b) => {
  const yearA = a.data.year || 0;
  const yearB = b.data.year || 0;
  return yearB - yearA;
});

const seo = {
  title: "Our Work",
  description: "Explore our case studies showcasing real results from AI consulting and digital transformation projects across industries.",
  type: "website" as const,
};
---

<BaseLayout seo={seo}>
  <section>
    <Wrapper variant="standard" class="py-12">
      <div class="max-w-2xl">
        <Kicker variant="default">Design Portfolio</Kicker>
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 text-balance font-medium tracking-tight mt-8 font-display"
          >Our Work</Text
        >
        <Text
          tag="p"
          variant="textBase"
          class="text-base-600 lg:text-balance mt-4"
        >
          We build amazing websites across different industries so that our clients can drive amazing leads.
        </Text>
      </div>
      <div
        class="grid grid-cols-1 lg:grid-cols-3 mt-12 gap-8 p-8 lg:p-12 bg-base-70"
      >
        {allCaseStudies.map((caseStudy) => <SingleWorkCard post={caseStudy} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
