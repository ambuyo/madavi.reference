---
import AuthorLayout from "@/layouts/AuthorLayout.astro";
import { getPosts, getPostsByAuthor } from "@/lib/data";

export const prerender = false;

const POSTS_PER_PAGE = 20;

const { username: usernameParam } = Astro.params;
if (!usernameParam) return Astro.redirect("/blog");

const parts = usernameParam.split("/");
const authorSlug = parts[0];
const pageParam = parts[1] ? parseInt(parts[1]) : 1;

// Find author info from any post
const allPosts = await getPosts();
const authorPost = allPosts.find((post) => post.data.author?.slug === authorSlug);

if (!authorPost?.data.author) {
  return Astro.redirect("/blog");
}

const author = authorPost.data.author;

// Get all posts by this author
const authorPosts = await getPostsByAuthor(authorSlug);

// Pagination
const totalPages = Math.ceil(authorPosts.length / POSTS_PER_PAGE);
const currentPage = Math.min(Math.max(pageParam, 1), totalPages) || 1;

if (currentPage !== pageParam) {
  return Astro.redirect(`/blog/author/${authorSlug}${currentPage > 1 ? `/${currentPage}` : ""}`);
}

const startIdx = (currentPage - 1) * POSTS_PER_PAGE;
const paginatedPosts = authorPosts.slice(startIdx, startIdx + POSTS_PER_PAGE);

const pagination = {
  currentPage,
  totalPages,
  totalPosts: authorPosts.length,
  hasNextPage: currentPage < totalPages,
  hasPrevPage: currentPage > 1,
  nextPageUrl: currentPage < totalPages ? `/blog/author/${authorSlug}/${currentPage + 1}` : null,
  prevPageUrl: currentPage > 1 ? `/blog/author/${authorSlug}${currentPage - 1 > 1 ? `/${currentPage - 1}` : ""}` : null,
};
---

<AuthorLayout
  author={author}
  posts={paginatedPosts}
  pagination={pagination}
/>
