---
import SingleBlogLayout from "@/layouts/SingleBlogLayout.astro";
import { getPostBySlug } from "@/lib/data";

export const prerender = false;

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect("/404");
}

const imageUrl = typeof post.data.image === "string"
  ? post.data.image
  : post.data.image?.url || "";

const categoryName = post.data.categories?.[0]?.name || "Blog";
const wordCount = post.plainText?.trim().split(/\s+/).length || 0;
const readingTimeMinutes = Math.ceil(wordCount / 200);
const readingTime = readingTimeMinutes < 1 ? "1 min" : `${readingTimeMinutes} min`;

// Get author name from team field or WordPress author data
const authorName = post.data.team || (post.data as any)?._embedded?.author?.[0]?.name || "Madavi";
---

<SingleBlogLayout
  title={post.data.title}
  category={categoryName}
  date={post.data.pubDate || new Date()}
  readingTime={readingTime}
  image={imageUrl}
  description={post.data.description}
  seoTitle={post.data.title}
  seoDescription={post.data.description}
  seoImage={imageUrl}
  compiledBy={authorName}
>
  {post.body && <div set:html={post.body} />}
</SingleBlogLayout>
