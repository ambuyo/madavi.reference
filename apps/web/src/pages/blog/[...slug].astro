---
import SingleBlogLayout from "@/layouts/SingleBlogLayout.astro";
import { getPostBySlug } from "@/lib/data";

export const prerender = false;

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect("/404");
}

const imageUrl = typeof post.data.image === "string"
  ? post.data.image
  : post.data.image?.url || "";

const categoryName = post.data.categories?.[0]?.name || "Blog";
const categorySlug = post.data.categories?.[0]?.slug;
const wordCount = post.plainText?.trim().split(/\s+/).length || 0;
const readingTimeMinutes = Math.ceil(wordCount / 200);
const readingTime = readingTimeMinutes < 1 ? "1 min" : `${readingTimeMinutes} min`;

const authorName = post.data.team || post.data.author?.name || "Madavi";
const authorAvatar = post.data.author?.avatar;
const authorSlug = post.data.author?.slug;

const seoTitle = post.data.seo?.metaTitle || post.data.title;
const seoDescription = post.data.seo?.metaDescription || post.data.description;
const seoImage = post.data.seo?.ogImage?.asset?.url || imageUrl;
---

<SingleBlogLayout
  title={post.data.title}
  category={categoryName}
  categorySlug={categorySlug}
  date={post.data.pubDate || new Date()}
  readingTime={readingTime}
  image={imageUrl}
  description={post.data.description}
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  seoImage={seoImage}
  compiledBy={authorName}
  authorAvatar={authorAvatar}
  authorSlug={authorSlug}
>
  {post.body && <div set:html={post.body} />}
</SingleBlogLayout>
