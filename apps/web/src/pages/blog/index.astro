---
export const prerender = false;
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Sections: In order of use
import BlogFeatured from "@/components/blog/landing/BlogFeatured.astro";
import AIStudioBlog from "@/components/blog/landing/AIStudioBlog.astro";
import GrowthMarketingBlog from "@/components/blog/landing/GrowthMarketingBlog.astro";
import Aside1 from "@/components/blog/landing/Aside1.astro";
import ContentMarketingBlog from "@/components/blog/landing/ContentMarketingBlog.astro";
import SeoMarketingBlog from "@/components/blog/landing/SeoMarketingBlog.astro";
import Categories1 from "@/components/blog/landing/Categories1.astro";
import Categories2 from "@/components/blog/landing/Categories2.astro";
import WebDesignBlog from "@/components/blog/landing/WebDesignBlog.astro";
// Adverts
import AdvertAside from "@/components/advert/AdvertAside.astro";
import AdvertInline from "@/components/advert/AdvertInline.astro";

const seo = {
  title: "Blog and Insights",
  description: "Read insights and articles about AI consulting, digital transformation, and business strategy from Madavi.",
  type: "website" as const,
};
---

<BaseLayout seo={seo}>
  <section>
    <Wrapper variant="standard" class="py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-0">
        <div class="lg:col-span-3 lg:pr-8">
          <BlogFeatured />
          <div class="flex flex-col gap-12 mt-8">
            <AIStudioBlog />
            <GrowthMarketingBlog />
            <AdvertInline />
          </div>
        </div>
        <div class="lg:pl-8">
          <div class="lg:sticky lg:top-10 lg:z-20">
            <Aside1 />
            <AdvertAside />
          </div> 
        </div>
      </div>
      <div class="flex flex-col gap-4 mt-12">
        <ContentMarketingBlog />
      </div>
    </Wrapper>
  </section>
  <Categories1 />
  <SeoMarketingBlog />
  <Categories2 />
  <section>
    <Wrapper variant="standard" class="py-12">
      <WebDesignBlog />
    </Wrapper>
  </section>
</BaseLayout>
  