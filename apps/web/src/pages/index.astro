---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
// Landing Components
import MainHomeHeroAlt from "@/components/landing/MainHomeHeroAlt.astro";
import Stats1 from "@/components/stats/Stats1.astro";
import HomeServices from "@/components/landing/HomeServices.astro";
import IndustriesOverview from "@/components/landing/IndustriesPreview.astro";
import MadaviStats from "@/components/landing/MadaviStats.astro";
import OurWorkPreview from "@/components/landing/OurWorkPreview.astro";
import ProblemSection from "@/components/landing/ProblemSection.astro";
import TestimonialsPreview from "@/components/landing/TestimonialsPreview.astro";
import SolutionsOverview from "@/components/landing/SolutionsOverview.astro";

import BlogPreview from "@/components/landing/BlogPreview.astro";

const seo = {
  title: "AI Advisory Consulting Firm",
  description: "AI Advisory Consulting Firm helping organizations build AI adoption capability before deploying technology. Strategic advisory for C-suite leaders.",
  type: "website" as const,
};
---

<BaseLayout seo={seo} navVariant="transparent">
  <MainHomeHeroAlt />
  <Stats1 />
  <ProblemSection />
    <MadaviStats />
  <HomeServices />
  <OurWorkPreview />
  <IndustriesOverview />

  <TestimonialsPreview />
  <SolutionsOverview />
  <BlogPreview />
</BaseLayout> 
