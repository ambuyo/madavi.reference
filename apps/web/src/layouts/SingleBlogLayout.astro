---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Seo from "@/components/fundations/head/Seo.astro";

interface Props {
  title: string;
  category: string;
  date: Date;
  readingTime?: string;
  image?: string | any;
  imageAlt?: string;
  description?: string;
  seoTitle?: string;
  seoDescription?: string;
  seoImage?: string | any;
  fullSummary?: any[];
  compiledBy?: string;
  authorAvatar?: string | any;
  authorSlug?: string;
  categorySlug?: string;
  downloadUrl?: string;
}

const {
  title,
  category,
  date,
  readingTime,
  image,
  imageAlt,
  description,
  seoTitle,
  seoDescription,
  seoImage,
  fullSummary,
  compiledBy,
  authorAvatar,
  authorSlug,
  categorySlug,
  downloadUrl,
} = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const seoImageUrl = typeof seoImage === "string" ? seoImage : seoImage?.url || seoImage?.src;
const imageUrl = typeof image === "string" ? image : image?.url || image?.src;
---

<BaseLayout>
  <Seo
    title={seoTitle || title}
    description={seoDescription || description}
    image={seoImageUrl}
    type="article"
  />

  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="grid lg:grid-cols-3 gap-12">
        {/* Left Column */}
        <div>
          <div class="lg:sticky lg:top-48">
            {/* Title */}
            <Text
              tag="h1"
              variant="displaySM"
              class="text-accent-800 font-display text-balance mb-4"
              style="font-size: 25px;"
            >
              {title}
            </Text>

            {/* Category & Publication Date */}
            <div class="mt-4 space-y-2">
              {categorySlug ? (
                <a
                  href={`/blog/cat/${categorySlug}`}
                  class="font-semibold text-base-600 hover:text-accent-700 transition-colors"
                  style="font-family: 'Geom', sans-serif; font-weight: 600; font-size: 15px;"
                >
                  {category.replace(/\w+/g, (w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())}
                </a>
              ) : (
                <p
                  class="font-semibold text-base-600"
                  style="font-family: 'Geom', sans-serif; font-weight: 600; font-size: 15px;"
                >
                  {category.replace(/\w+/g, (w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())}
                </p>
              )}
              {readingTime && (
                <Text tag="p" variant="textXS" class="text-base-600">
                  {readingTime} read
                </Text>
              )}
              <Text tag="p" variant="textXS" class="text-base-600">
                Published on: {formattedDate}
              </Text>
            </div>

            {/* Divider */}
            <div class="mt-8 pt-8 border-t border-base-300">
              {/* Author */}
              {compiledBy && (
                <div>
                  <Text tag="p" variant="textXS" class="text-base-500 uppercase font-medium mb-3">
                    Written by
                  </Text>
                  <div class="flex items-center gap-3">
                    {authorAvatar && (
                      <div class="flex-shrink-0">
                        {authorSlug ? (
                          <a href={`/blog/author/${authorSlug}`}>
                            <img
                              src={typeof authorAvatar === "string" ? authorAvatar : authorAvatar?.url || authorAvatar?.src}
                              alt={compiledBy}
                              class="w-12 h-12 rounded-full object-cover hover:opacity-80 transition-opacity"
                            />
                          </a>
                        ) : (
                          <img
                            src={typeof authorAvatar === "string" ? authorAvatar : authorAvatar?.url || authorAvatar?.src}
                            alt={compiledBy}
                            class="w-12 h-12 rounded-full object-cover"
                          />
                        )}
                      </div>
                    )}
                    <div>
                      {authorSlug ? (
                        <a href={`/blog/author/${authorSlug}`} class="hover:text-accent-700 transition-colors">
                          <Text tag="p" variant="textBase" class="text-base-900 font-semibold">
                            {compiledBy}
                          </Text>
                        </a>
                      ) : (
                        <Text tag="p" variant="textBase" class="text-base-900 font-semibold">
                          {compiledBy}
                        </Text>
                      )}
                      <Text tag="p" variant="textXS" class="text-base-500 mt-1">
                        Madavi Team
                      </Text>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>

        {/* Right Column - Full Content */}
        <div class="lg:col-span-2">
          {/* Featured Image */}
          {imageUrl && (
            <div class="mb-8 rounded-lg overflow-hidden">
              <img
                src={imageUrl}
                alt={imageAlt || title}
                class="w-full h-auto object-cover"
              />
            </div>
          )}

          {/* Title */}
          <Text
            tag="h1"
            variant="displaySM"
            class="text-accent-800 font-display text-balance mb-8 w-full"
            style="font-size: 30px;"
          >
            {title}
          </Text>

          {/* Article Body */}
          <div class="prose prose-lg max-w-none">
            {fullSummary && (
              <div class="text-base-900 leading-relaxed">
                {fullSummary.map((block: any, idx: number) => {
                  if (block._type === "block") {
                    const style = block.style || "normal";
                    const text = block.children
                      ?.map((child: any) => {
                        let content = child.text || "";
                        if (child.marks?.includes("strong"))
                          content = `<strong>${content}</strong>`;
                        if (child.marks?.includes("em"))
                          content = `<em>${content}</em>`;
                        if (child.marks?.includes("code"))
                          content = `<code>${content}</code>`;
                        if (child.marks?.includes("underline"))
                          content = `<u>${content}</u>`;
                        return content;
                      })
                      .join("");

                    if (style === "h1")
                      return (
                        <h1 key={idx} class="text-3xl font-bold mt-6 mb-4">
                          <Fragment set:html={text} />
                        </h1>
                      );
                    if (style === "h2")
                      return (
                        <h2 key={idx} class="text-2xl font-bold mt-5 mb-3">
                          <Fragment set:html={text} />
                        </h2>
                      );
                    if (style === "h3")
                      return (
                        <h3 key={idx} class="text-xl font-bold mt-4 mb-2">
                          <Fragment set:html={text} />
                        </h3>
                      );
                    if (style === "blockquote")
                      return (
                        <blockquote
                          key={idx}
                          class="border-l-4 border-accent-400 pl-4 py-2 my-4 italic text-base-700"
                        >
                          <Fragment set:html={text} />
                        </blockquote>
                      );
                    return (
                      <p key={idx} class="mb-4">
                        <Fragment set:html={text} />
                      </p>
                    );
                  }

                  if (block._type === "block" && block.listItem) {
                    const isOrdered = block.listItem === "number";
                    const text = block.children
                      ?.map((child: any) => {
                        let content = child.text || "";
                        if (child.marks?.includes("strong"))
                          content = `<strong>${content}</strong>`;
                        if (child.marks?.includes("em"))
                          content = `<em>${content}</em>`;
                        return content;
                      })
                      .join("");
                    return (
                      <li
                        key={idx}
                        class={`mb-2 ${isOrdered ? "list-decimal" : "list-disc"} list-inside`}
                      >
                        <Fragment set:html={text} />
                      </li>
                    );
                  }

                  return null;
                })}
              </div>
            )}

            {!fullSummary && <slot />}
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
