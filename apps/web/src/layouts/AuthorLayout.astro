---
import categoryHeaderBg from "@/images/blog/categories/category-header.jpg";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BlogCard from "@/components/blog/categories/BlogCard1.astro";

interface Props {
  author: {
    name: string;
    slug: string;
    avatar?: string;
    bio?: string;
  };
  posts: any[];
  pagination?: {
    currentPage: number;
    totalPages: number;
    totalPosts: number;
    hasNextPage: boolean;
    hasPrevPage: boolean;
    nextPageUrl: string | null;
    prevPageUrl: string | null;
  };
}

const { author, posts, pagination } = Astro.props;

const seoData = {
  title: `Posts by ${author.name}`,
  description: `Browse all articles written by ${author.name}`,
  seoType: "website" as const,
  canonical: Astro.url.pathname,
};
---

<BaseLayout navVariant="transparent" {...seoData}>
  <section class="relative overflow-hidden -mt-24 pt-24" data-parallax-container>
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={{backgroundImage: `url(${categoryHeaderBg.src})`}}
      data-parallax
    />
    <div class="absolute inset-0 bg-black/50" />

    <Wrapper variant="standard" class="relative py-20 lg:py-32">
      <div class="max-w-3xl mx-auto text-center">
        {author.avatar && (
          <img
            src={author.avatar}
            alt={author.name}
            width="96"
            height="96"
            class="w-24 h-24 rounded-full object-cover mx-auto mb-6 ring-4 ring-white/30"
          />
        )}
        <Text
          tag="p"
          variant="textSM"
          class="text-white/60 uppercase tracking-widest mb-3"
        >
          Written by
        </Text>
        <Text
          tag="h1"
          variant="displayLG"
          class="font-medium tracking-tight text-white leading-tight"
        >
          {author.name}
        </Text>

        <div class="flex items-center justify-center gap-2 mt-8">
          <span class="text-white font-bold text-lg">{posts.length}</span>
          <span class="text-white/60">•</span>
          <span class="text-white/80">{posts.length === 1 ? "Article" : "Articles"}</span>
        </div>
      </div>
    </Wrapper>
  </section>

  {author.bio && (
    <div class="border-b border-base-200">
      <Wrapper variant="standard" class="py-10 lg:py-14">
        <div class="grid grid-cols-4 gap-8 items-start">
          {author.avatar && (
            <img
              src={author.avatar}
              alt={author.name}
              class="w-full aspect-square object-cover col-span-1"
              style="border-radius: 15px;"
            />
          )}
          <div class={author.avatar ? "col-span-3" : "col-span-4"}>
            <Text tag="p" variant="textLG" class="text-base-900 font-semibold">
              {author.name}
            </Text>
            <div class="mt-2 space-y-3">
              {author.bio.match(/[^.!?]+[.!?]+/g)?.map((sentence) => (
                <Text tag="p" variant="textBase" class="text-base-600 leading-relaxed">
                  {sentence.trim()}
                </Text>
              ))}
            </div>
          </div>
        </div>
      </Wrapper>
    </div>
  )}

  <Wrapper variant="standard" class="py-16 lg:py-24">
    {
      posts.length > 0 ? (
        <div>
          <div class="flex justify-end mb-12">
            <Button isLink size="sm" variant="secondary" href="/blog" class="w-fit">
              ← Back to all posts
            </Button>
          </div>
          <div class="bg-base-50 p-8 lg:p-12 rounded-lg">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-24">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </div>

          {pagination && pagination.totalPages > 1 && (
            <div class="flex items-center justify-center gap-4 mt-16">
              {pagination.hasPrevPage && (
                <Button isLink size="sm" variant="secondary" href={pagination.prevPageUrl}>
                  ← Previous
                </Button>
              )}
              <span class="text-base-600 text-sm">
                Page {pagination.currentPage} of {pagination.totalPages}
              </span>
              {pagination.hasNextPage && (
                <Button isLink size="sm" variant="secondary" href={pagination.nextPageUrl}>
                  Next →
                </Button>
              )}
            </div>
          )}
        </div>
      ) : (
        <div class="text-center py-16">
          <Text tag="p" variant="textLG" class="text-base-600 mb-8">
            No posts found for this author yet.
          </Text>
          <Button isLink size="md" variant="primary" href="/blog">
            Browse all posts
          </Button>
        </div>
      )
    }
  </Wrapper>
</BaseLayout>

<script is:inline>
  function initParallax() {
    const container = document.querySelector("[data-parallax-container]");
    const parallaxElement = document.querySelector("[data-parallax]");
    if (!container || !parallaxElement) return;
    function updateParallax() {
      const rect = container.getBoundingClientRect();
      const scrolled = window.scrollY;
      const offset = Math.min(scrolled * 0.5, rect.height * 0.3);
      parallaxElement.style.transform = `translateY(${offset}px)`;
    }
    window.addEventListener("scroll", updateParallax, { passive: true });
    updateParallax();
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initParallax);
  } else {
    initParallax();
  }
</script>
