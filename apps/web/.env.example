# Sanity configuration
# Get these from https://sanity.io/manage
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=

# WordPress configuration (for caching posts at build time)
# Get your app password from: https://cms.madavi.co/wp-admin → Users → Edit Profile
WP_USERNAME=
WP_APP_PASSWORD=

# CDN configuration for image optimization
PUBLIC_R2_CDN_URL=https://images.madavi.co

# Google Analytics 4
PUBLIC_GA4_ID=

# Zoho Bigin CRM (proposal form submissions)
# Get credentials at: https://api-console.zoho.com → Server-based Application
# Scope needed: ZohoBigin.modules.ALL,ZohoBigin.settings.ALL
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DATACENTER=com

# Cloudflare Turnstile (bot protection on all forms)
# Get keys at: https://dash.cloudflare.com → Turnstile
# Use test keys for local dev: site key 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
